      {
       "data": "Out[156]= \\begin{array}{|c|c|c|}\\hline\\left\\{1,1\\right\\} & 3 & \\mathrm{True}\\\\\\hline\\left\\{1,2\\right\\} & 3 & \\mathrm{True}\\\\\\hline\\left\\{1,3\\right\\} & 3 & \\mathrm{True}\\\\\\hline\\left\\{2,1\\right\\} & 3 & \\mathrm{True}\\\\\\hline\\left\\{2,2\\right\\} & 6 & \\mathrm{True}\\\\\\hline\\left\\{2,3\\right\\} & 6 & \\mathrm{True}\\\\\\hline\\left\\{3,1\\right\\} & 3 & \\mathrm{True}\\\\\\hline\\left\\{3,2\\right\\} & 6 & \\mathrm{True}\\\\\\hline\\left\\{3,3\\right\\} & 10 & \\mathrm{True}\\\\\\hline\\end{array}",
