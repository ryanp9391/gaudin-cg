  {
   "kind": 2,
   "value": "(* Approach 2: term-by-term via closed-form res1/res0 *)\nAbsoluteTiming[\n  closedForm88 = Sum[polyCoeffs[[n + 1]] (res1[n, 8, 8] + res0[n, 8, 8]), {n, 0, 20}] // Simplify;\n]",
   "languageId": "wolfram",
