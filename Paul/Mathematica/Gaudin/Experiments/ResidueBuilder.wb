     "id": "bde3f490-d336-41ea-b5ea-6952e852dd2e"
    }
   ],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(* Approach 3: proposed - truncated power series / convolution, no generic Residue, no LaguerreL *)\nfastResidue[poly_, S1_Integer, S2_Integer, w_] := Module[{t, g1, r1, g0, r0},\n   g1 = Series[(poly /. u -> 1 + t) (1 + t)^(-S2) Exp[w (1 + t)], {t, 0, S1 - 1}];\n   r1 = SeriesCoefficient[g1, S1 - 1];\n   g0 = Series[poly Exp[w u]/(u - 1)^S1, {u, 0, S2 - 1}];\n   r0 = SeriesCoefficient[g0, S2 - 1];\n   r1 + r0\n   ];\nAbsoluteTiming[\n  fast88 = fastResidue[poly20, 8, 8, w] // Simplify;\n]",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"50770\" data-output-id=\"40\" data-out-n=\"52\" data-sub-idx=\"2\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"10\" data-sub-start=\"8\" data-sub-end=\"10\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[52]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrggrmje-6xwncac\" data-page-width-em=\"21\" data-latex-b64=\"XGxlZnRcezAuMDc3MDU1LFxtYXRocm17TnVsbH1ccmlnaHRcfQ==\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">{</span><span class=\"mord\">0.077055</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\"><span class=\"mord mathrm\">Null</span></span><span class=\"mclose delimcenter\" style=\"top:0em;\">}</span></span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
      },
      {
       "data": "Out[52]= \\left\\{0.077055,\\mathrm{Null}\\right\\}",
       "mime": "text/plain"
      }
     ],
     "id": "396d6739-d6cf-4305-a6a0-61f7bc3748ce"
    }
   ],
   "metadata": {}
