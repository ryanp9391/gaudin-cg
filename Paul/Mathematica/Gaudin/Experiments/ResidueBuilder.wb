      {
       "data": "Out[58]= \\begin{array}{|c|c|c|c|}\\hline\\text{S1=S2} & \\text{direct Residue (s)} & \\text{closed-form Laguerre (s)} & \\text{fastResidue (s)}\\\\\\hline50 & 0.052777 & 0.025125 & 0.017995\\\\\\hline100 & 0.109625 & 0.040383 & 0.044044\\\\\\hline200 & 0.737406 & 0.092564 & 0.249711\\\\\\hline400 & 5.342746 & 0.246564 & 1.75029\\\\\\hline\\end{array}",
