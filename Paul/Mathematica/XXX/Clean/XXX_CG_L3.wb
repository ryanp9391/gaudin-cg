       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"598685\" data-output-id=\"138\" data-out-n=\"210\" data-sub-idx=\"0\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"41\" data-sub-start=\"0\" data-sub-end=\"0\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[210]=</span></div><div class=\"wl-output-content\"><pre class=\"vscode-wolfram-text-output\">No output at Out[210]</pre></div></div>",
