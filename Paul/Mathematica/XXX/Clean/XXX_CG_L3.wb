  {
   "kind": 2,
   "value": "(*transfer matrix in fundamental representation with diagonal twist*)\nt3diag[λ1_,λ2_,λ3_][1,1][u_]:=Sum[T[λ1,λ2,λ3][i,i][u]κ[i],{i,2}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*global Lie algebra generators (triple coproduct)*)\nClearAll[EE]\nEE[λ1_,λ2_,λ3_][i_,j_]:=KroneckerProduct[Ee[λ1][i,j],IdentityMatrix[dim[{λ2,0}]],IdentityMatrix[dim[{λ3,0}]]]+KroneckerProduct[IdentityMatrix[dim[{λ1,0}]],Ee[λ2][i,j],IdentityMatrix[dim[{λ3,0}]]]+KroneckerProduct[IdentityMatrix[dim[{λ1,0}]],IdentityMatrix[dim[{λ2,0}]],Ee[λ3][i,j]];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*central charge*)\nTable[EE[λ1,λ2,λ3][1,1]+EE[λ1,λ2,λ3][2,2]-(λ1+λ2+λ3)IdentityMatrix[dim[{λ1,0}]dim[{λ2,0}]dim[{λ3,0}]],{λ1,1,3},{λ2,1,3},{λ3,1,3}]//Flatten//Union",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"598685\" data-output-id=\"123\" data-out-n=\"146\" data-sub-idx=\"1\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"20\" data-sub-start=\"1\" data-sub-end=\"1\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[146]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrma4gof-6ph4y07\" data-page-width-em=\"33\" data-latex-b64=\"XGxlZnRcezBccmlnaHRcfQ==\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">{</span><span class=\"mord\">0</span><span class=\"mclose delimcenter\" style=\"top:0em;\">}</span></span></span></span></span></span></div></div></div></div>",
