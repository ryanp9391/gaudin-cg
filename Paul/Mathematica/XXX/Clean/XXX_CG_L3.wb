      {
       "data": "Out[187]= \\langle\\!\\lvert \\left\\{0,0\\right\\}\\to -1.0023661289808585-2.5229544323858897\\,\\mathrm{i},\\left\\{1,0\\right\\}\\to -1.9591204341670663-0.8728625487854049\\,\\mathrm{i},\\left\\{1,1\\right\\}\\to -0.08422543749008554+0.27639976349988676\\,\\mathrm{i},\\left\\{1,2\\right\\}\\to 1.0375469819606056 -0.9937091985069969\\,\\mathrm{i},\\left\\{2,0\\right\\}\\to -1.9591204341670663+0.8728625487854049\\,\\mathrm{i},\\left\\{2,1\\right\\}\\to -0.08422543749008554-0.27639976349988676\\,\\mathrm{i},\\left\\{2,2\\right\\}\\to 1.0375469819606056 +0.9937091985069969\\,\\mathrm{i},\\left\\{3,0\\right\\}\\to -1.0023661289808585+2.5229544323858897\\,\\mathrm{i}\\rvert\\!\\rangle",
