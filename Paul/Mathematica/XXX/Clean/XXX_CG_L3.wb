       "mime": "text/plain"
      }
     ],
     "id": "8bff086e-f8ea-47e4-b8bb-7b043db2873e"
    }
   ],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*quantum determinant*)\nClearAll[qdetT];\nqdetT[λ1_,λ2_,λ3_][u_]:=T[λ1,λ2,λ3][1,1][u].T[λ1,λ2,λ3][2,2][u-h]-T[λ1,λ2,λ3][2,1][u].T[λ1,λ2,λ3][1,2][u-h];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*Fusion/Hirota hierarchy for the three-site transfer matrices t3[λ1,λ2,λ3][1,s][u] — algebraic\n  form IDENTICAL to the L2 notebook (references T(u)/t3(u) only, not L explicitly); only the\n  domain (λ1,λ2,λ3 a triple, not a pair) changes. No standalone check cell here — correctness is\n  implicit in the SoV covector eigenvalue check in Task 7, matching the L2 notebook's convention.*)\nt3[λ1_,λ2_,λ3_][0,s_][u_]:=IdentityMatrix[dim[{λ1,0}]dim[{λ2,0}]dim[{λ3,0}]];\nt3[λ1_,λ2_,λ3_][a_,0][u_]:=IdentityMatrix[dim[{λ1,0}]dim[{λ2,0}]dim[{λ3,0}]];\nt3[λ1_,λ2_,λ3_][2,1][u_]:=χ2 qdetT[λ1,λ2,λ3][u];\nt3[λ1_,λ2_,λ3_][1,s_][u_]:=t3[λ1,λ2,λ3][1,s][u]=t3[λ1,λ2,λ3][1,s-1][u].t3[λ1,λ2,λ3][1,1][u+(s-1)h]-t3[λ1,λ2,λ3][2,1][u+(s-1)h].t3[λ1,λ2,λ3][1,s-2][u];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*Qθ factor for the three-site chain. (L2 also kept a single-site Qθ1 factor for parity with its\n  source file even though it was never used downstream — dropped here as unused/YAGNI.)*)\nClearAll[Qθ];\nQθ[u_]:=(u-θ1)(u-θ2)(u-θ3);",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*SoV B-operator for L=3: the bare (1,1) monodromy element (no G, no trace) — same convention as\n  B2[λ1,λ2][u]=T[λ1,λ2][1,1][u] at L=2.*)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "ClearAll[B3];\nB3[λ1_,λ2_,λ3_][u_]:=T[λ1,λ2,λ3][1,1][u];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*SoV pseudovacuum for L=3 as the tensor product of the three single-site lowest-weight\n  covectors.*)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "ClearAll[xSingle,x3];\nxSingle[λ_][{0}]:={Table[KroneckerDelta[ii,dim[{λ,0}]],{ii,1,dim[{λ,0}]}]};\nx3[λ1_,λ2_,λ3_][{0,0,0}]:=KroneckerProduct[xSingle[λ1][{0}],xSingle[λ2][{0}],xSingle[λ3][{0}]];\n\nx3[λ1_,λ2_,λ3_][{s1_,s2_,s3_}] := x3[λ1,λ2,λ3][{s1,s2,s3}] =\n  x3[λ1,λ2,λ3][{0,0,0}].t3[λ1,λ2,λ3][1,s1][θ1].t3[λ1,λ2,λ3][1,s2][θ2].t3[λ1,λ2,λ3][1,s3][θ3]/\n  (Product[Qθ[θ1 + (-λ1 + k - 1) h], {k, 1, s1}] Product[Qθ[θ2 + (-λ2 + k - 1) h], {k, 1, s2}] Product[Qθ[θ3 + (-λ3 + k - 1) h], {k, 1, s3}]);",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*checking x3 diagonalizes B3 — λ-range {1,2} (not L2's {1,2,3}) to bound compute cost at three\n  sites (max dim (λ+1)^3 grows fast); still covers the general/unequal-λ case.*)\nTable[Table[x3[λ1,λ2,λ3][{s1,s2,s3}].B3[λ1,λ2,λ3][u]-(u-θ1-h s1)(u-θ2-h s2)(u-θ3-h s3)x3[λ1,λ2,λ3][{s1,s2,s3}],{s1,0,λ1},{s2,0,λ2},{s3,0,λ3}],{λ1,1,2},{λ2,1,2},{λ3,1,2}]//Simplify//Flatten//Union",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"598685\" data-output-id=\"125\" data-out-n=\"164\" data-sub-idx=\"1\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"30\" data-sub-start=\"2\" data-sub-end=\"2\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[164]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrma5gjo-rnvwr8f\" data-page-width-em=\"33\" data-latex-b64=\"\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1.2141em;vertical-align:-0.35em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\"><span class=\"delimsizing size1\">{</span></span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\"><span class=\"delimsizing size1\">(</span></span><span class=\"mord\">0.</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">×</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mord\">1</span><span class=\"mord\"><span class=\"mord\">0</span><span class=\"msupsub\"><span class=\"vlist-t\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8641em;\"><span style=\"top:-3.113em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\"><span class=\"mord mtight\">−</span><span class=\"mord mtight\">60</span></span></span></span></span></span></span></span></span><span class=\"mspace\" sty