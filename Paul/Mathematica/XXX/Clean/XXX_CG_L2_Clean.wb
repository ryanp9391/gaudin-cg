  {
   "kind": 2,
   "value": "(*OPg fixes the nontrivial generator so downstream code reads OPg[λ1,λ2][M,n][φ]. Degree in φ is ≤λ1.*)\nClearAll[OPg];\nOPg[λ1_, λ2_][M_, n_][φ_] := OP[λ1, λ2][genNontrivial[[1]], genNontrivial[[2]]][M, n][φ];\n(*smoke: degree in φ for a λ1=1 and a λ1=2 case*)\n{Exponent[OPg[1, 1][1, 0][φ] // Simplify, φ], Exponent[OPg[2, 1][1, 0][φ] // Simplify, φ]}",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"352969\" data-output-id=\"182\" data-out-n=\"197\" data-sub-idx=\"4\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"68\" data-sub-start=\"4\" data-sub-end=\"4\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[197]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrns6xdf-gds1l4c\" data-page-width-em=\"21\" data-latex-b64=\"XGxlZnRcezEsMlxyaWdodFx9\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">{</span><span class=\"mord\">1</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">2</span><span class=\"mclose delimcenter\" style=\"top:0em;\">}</span></span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
      },
      {
       "data": "Out[197]= \\left\\{1,2\\right\\}",
       "mime": "text/plain"
      }
     ],
     "id": "301e431d-6739-4d23-9d55-69371b222a4c"
    }
