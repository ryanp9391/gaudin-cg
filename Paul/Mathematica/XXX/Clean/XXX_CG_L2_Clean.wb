  {
   "kind": 2,
   "value": "(*Summary: worst deviation from the now-EXACT tensor factorization (ratio ≡ 1, no leftover\n  scalar) across the whole sweep. Columns of factResults: {λ1,λ2,s1,ratio,spread}.*)\n<|\n  \"max spread (ratio non-constancy)\" -> Max[factResults[[All, 5]]],\n  \"max |ratio - 1| over sweep\" -> Max[Abs[factResults[[All, 4]] - 1]],\n  \"num (λ1,λ2,s1) cases checked\" -> Length[factResults]\n|>",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"352969\" data-output-id=\"177\" data-out-n=\"170\" data-sub-idx=\"1\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"60\" data-sub-start=\"2\" data-sub-end=\"6\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[170]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrns6umv-juyt8nn\" data-page-width-em=\"21\" data-latex-b64=\"XGxhbmdsZVwhXGx2ZXJ0IFx0ZXh0e21heCBzcHJlYWQgKHJhdGlvIG5vbi1jb25zdGFuY3kpfVx0byAwLlwsLFx0ZXh0e21heCB8cmF0aW8gLSAxfCBvdmVyIHN3ZWVwfVx0byAwLlwsLFx0ZXh0e251bSAoJFxsYW1iZGEkMSwkXGxhbWJkYSQyLHMxKSBjYXNlcyBjaGVja2VkfVx0byAyN1xydmVydFwhXHJhbmdsZQ==\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">⟨</span><span class=\"mspace\" style=\"margin-right:-0.1667em;\"></span><span class=\"mopen\">∣</span><span class=\"mord text\"><span class=\"mord\">max spread (ratio non-constancy)</span></span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">→</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord\">0.</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord text\"><span class=\"mord\">max |ratio - 1| over sweep</span></span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">→</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord\">0.</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord text\"><span class=\"mord\">num (</span><span class=\"mord mathnormal\">λ</span><span class=\"mord\">1,</span><span class=\"mord mathnormal\">λ</span><span class=\"mord\">2,s1) cases checked</span></span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">→</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord\">27</span><span class=\"mclose\">∣</span><span class=\"mspace\" style=\"margin-right:-0.1667em;\"></span><span class=\"mclose\">⟩</span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
