       "data": "Out[119]= \\left\\{0\\right\\}",
       "mime": "text/plain"
      }
     ],
     "id": "d901ca5d-ce5a-4d17-8abf-b1cbd4ab87d9"
    }
   ],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*Lax operator for a general gl(3) rep λ={λ1,λ2,λ3} at the site*)\nClearAll[L];\nL[λ_][i_,j_][u_]:=IdentityMatrix[dim[λ]] u KroneckerDelta[i,j] - h JJ[j,i,λ];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*Numeric parameters*)\nθ1 = 1/3;\nθ2 = 1/7;\nh = 1;\nz[1] = Exp[π I 2/5];\nz[2] = Exp[π I 3/4];\nz[3] = Exp[π I 5/9];\nu0=N[Zeta[3],50];\nv0=N[Zeta[5],50];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*companion twist matrix eith eigenvalues z[1],z[2],z[3]*)\nG={{χ1,-χ2,χ3},{1,0,0},{0,1,0}};\nχ1=z[1]+z[2]+z[3];\nχ2=z[1] z[2]+z[1]z[3]+z[2]z[3];\nχ3=z[1]z[2]z[3];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*monodromy with no twist, diagonal twist, and companion twist*)\nClearAll[T,Tg,TG];\nT[λ1_,λ2_][i_,j_][u_]:=Sum[KroneckerProduct[L[λ1][i,ii][u-θ1],L[λ2][ii,j][u-θ2]],{ii,3}];\nTg[λ1_,λ2_][i_,j_][u_]:= z[i] T[λ1,λ2][i,j][u];\nTG[λ1_,λ2_][i_,j_][u_]:=Sum[T[λ1,λ2][i,ii][u] G[[ii,j]],{ii,3}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*Yangian weights - eigenvalues of T[i,i] on the highest-weight state.\n  General rep: T[i,i]|hw> = (u-θ1-h λ1[[i]])(u-θ2-h λ2[[i]]) |hw>*)\nClearAll[ν,HWS];\nν[λ1_,λ2_][i_][u_]:=(u-θ1-h λ1[[i]])(u-θ2-h λ2[[i]]);\nHWS[λ1_,λ2_]:=Table[{KroneckerDelta[1,ii]},{ii,1,dim[λ1] dim[λ2]}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*checking highest-weights against the general ν, on non-symmetric reps*)\nTable[\n   T[r1,r2][i,i][u].HWS[r1,r2]-ν[r1,r2][i][u] HWS[r1,r2],\n   {i,3},{r1,testreps},{r2,testreps}]//Flatten//Union",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"429514\" data-output-id=\"31\" data-out-n=\"141\" data-sub-idx=\"1\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"13\" data-sub-start=\"1\" data-sub-end=\"3\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[141]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrq480kj-0lghg9o\" data-page-width-em=\"47\" data-latex-b64=\"XGxlZnRcezBccmlnaHRcfQ==\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">{</span><span class=\"mord\">0</span><span class=\"mclose delimcenter\" style=\"top:0em;\">}</span></span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
      },
      {
       "data": "Out[141]= \\left\\{0\\right\\}",
       "mime": "text/plain"
      }
     ],
     "id": "56310fd1-0653-4903-ba3f-fab51b39951e"
    }
   ],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*quantum minors (q-determinants) of the monodromy matrix with diagonal twist g or companion twist G*)\n\nqming[λ1_, λ2_][II_List, JJ_List][u_] := \n    qming[λ1, λ2][II, JJ][u] = \n    Sum[Signature[σ]\n        Dot @@ Table[Tg[λ1, λ2][II[[σ[[k]]]], JJ[[k]]][u - (k - 1) h], {k, \n             Length[II]}], {σ, Permutations[Range[Length[II]]]}];\n\nqminG[λ1_, λ2_][II_List, JJ_List][u_] := \n    qminG[λ1, λ2][II, JJ][u] = \n     Sum[Signature[σ] \n        Dot @@ Table[TG[λ1, λ2][II[[σ[[k]]]], JJ[[k]]][u - (k - 1) h], {k, \n            Length[II]}], {σ, Permutations[Range[Length[II]]]}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*transfer matrices with diagonal twist*)\nClearAll[tg];\ntg[λ1_,λ2_][a_,1][u_]:= Total[qming[λ1, λ2][#, #][u] & /@ Subsets[{1, 2, 3}, {a}]]\n\n(*transfer matrices with companion twist*)\nClearAll[tG];\ntG[λ1_,λ2_][a_,1][u_]:= Total[qminG[λ1, λ2][#, #][u] & /@ Subsets[{1, 2, 3}, {a}]]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*value of quantum determinant (χ3 carried here; general ν)*)\nClearAll[qdetT];\nqdetT[λ1_,λ2_][u_]:=χ3 ν[λ1,λ2][1][u-2h] ν[λ1,λ2][2][u-h] ν[λ1,λ2][3][u];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*checking quantum determinant is central with diagonal twist*)\nTable[\n  qdetT[r1,r2][u0] idd[r1,r2]-tg[r1,r2][3,1][u0],{r1,testreps},{r2,testreps}]//Chop[#,10^-30]&//Flatten//Union",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"429514\" data-output-id=\"32\" data-out-n=\"150\" data-sub-idx=\"1\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"17\" data-sub-start=\"1\" data-sub-end=\"2\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[150]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrq489by-m55jpfj\" data-page-width-em=\"47\" data-latex-b64=\"XGxlZnRcezBccmlnaHRcfQ==\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">{</span><span class=\"mord\">0</span><span class=\"mclose delimcenter\" style=\"top:0em;\">}</span></span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
