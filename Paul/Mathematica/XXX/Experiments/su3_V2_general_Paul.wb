       "data": "Out[98]= \\begin{matrix}\\left\\{\\text{H1H2n}\\to \\left\\{-4,4,0\\right\\},\\text{M}\\to \\left\\{4,0,4\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-3,2,0\\right\\},\\text{M}\\to \\left\\{4,1,3\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-3,2,1\\right\\},\\text{M}\\to \\left\\{4,1,3\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-2,0,0\\right\\},\\text{M}\\to \\left\\{4,2,2\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-2,0,1\\right\\},\\text{M}\\to \\left\\{4,2,2\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-2,3,0\\right\\},\\text{M}\\to \\left\\{3,1,4\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-2,3,1\\right\\},\\text{M}\\to \\left\\{3,1,4\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-1,-2,0\\right\\},\\text{M}\\to \\left\\{4,3,1\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-1,-2,1\\right\\},\\text{M}\\to \\left\\{4,3,1\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-1,1,0\\right\\},\\text{M}\\to \\left\\{3,2,3\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-1,1,1\\right\\},\\text{M}\\to \\left\\{3,2,3\\right\\},\\text{sumM}\\to 8\\right\\}\\\\\\left\\{\\text{H1H2n}\\to \\left\\{-1,1,2\\rig… [latex truncated: 3138 chars total]",
