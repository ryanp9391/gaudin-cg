       "data": "Out[87]= \\begin{matrix}\\left\\{\\left\\{1,0,0\\right\\},\\left\\{1,0,0\\right\\},0,1,0,\\left\\{1,1,2\\right\\}\\right\\}\\\\\\left\\{\\left\\{1,0,0\\right\\},\\left\\{1,0,0\\right\\},0,1,1,\\left\\{1,1,2\\right\\}\\right\\}\\\\\\left\\{\\left\\{1,0,0\\right\\},\\left\\{1,0,0\\right\\},1,-1,0,\\left\\{1,2,1\\right\\}\\right\\}\\\\\\left\\{\\left\\{1,0,0\\right\\},\\left\\{1,0,0\\right\\},1,-1,1,\\left\\{1,2,1\\right\\}\\right\\}\\\\\\left\\{\\left\\{1,0,0\\right\\},\\left\\{1,0,0\\right\\},-1,0,0,\\left\\{2,1,1\\right\\}\\right\\}\\\\\\left\\{\\left\\{1,0,0\\right\\},\\left\\{1,0,0\\right\\},-1,0,1,\\left\\{2,1,1\\right\\}\\right\\}\\\\\\left\\{\\left\\{1,0,0\\right\\},\\left\\{1,0,0\\right\\},2,0,0,\\left\\{0,2,2\\right\\}\\right\\}\\\\\\left\\{\\left\\{1,0,0\\right\\},\\left\\{1,0,0\\right\\},0,-2,0,\\left\\{2,2,0\\right\\}\\right\\}\\\\\\left\\{\\left\\{1,0,0\\right\\},\\left\\{1,0,0\\right\\},-2,2,0,\\left\\{2,0,2\\right\\}\\right\\}\\\\\\left\\{\\left\\{2,0,0\\right\\},\\left\\{1,1,0\\right\\},0,-1,0,\\left\\{2,2,1\\right\\}\\right\\}\\\\\\left\\{\\left\\{2,0,0\\right\\},\\left\\{1,1,0\\right\\},0,-1,1,\\left\\{2,2,1\\right\\}\\right\\}\\\\\\left\\{\\left\\{2,0,0\\right\\},\\left\\{1,1,0\\right\\},0,-1,2,\\left\\{2,2,1\\right\\}\\right\\}\\\\\\left\\{\\left\\{2,0,0\\right\\},\\left\\{1,1,0\\right\\},-1,1,0,\\left\\{2,1,2\\right\\}\\right\\}\\\\\\left\\{\\left\\{2,0,0\\right\\},\\left\\{1,1,0\\right\\},-1,1,1,\\left\\{2,1,2\\ri… [latex truncated: 8598 chars total]",
