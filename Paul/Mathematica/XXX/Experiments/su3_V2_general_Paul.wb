     "id": "14ef9027-c7ee-4a7e-9e73-c3d353017886"
    }
   ],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*checking quantum determinant is central with companion twist*)\nTable[\n  qdetT[r1,r2][u0] idd[r1,r2]-tG[r1,r2][3,1][u0],{r1,testreps},{r2,testreps}]//Chop[#,10^-30]&//Flatten//Union",
   "languageId": "wolfram",
   "outputs": [
