  {
   "kind": 2,
   "value": "Eigensystem[tg[{2, 1, 0}, {2, 1, 0}][1, 1][u0] // N];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*coefficient matrices of tau1=tg[.][1,1] (deg 2 in u) and tau2=tg[.][2,1] (deg 4 in u),\n  extracted by CoefficientList in a dummy variable uu so tg[..][..][uu] is treated as a polynomial in uu.\n  c1={C0,C1,C2} with tau1(u)=Sum_k C_k u^k (index k+1 in the list); c2={D0,...,D4} similarly for tau2.*)\nClearAll[tgCoeffs];\ntgCoeffs[λ1_, λ2_] := tgCoeffs[λ1, λ2] = Module[{uu, m1, m2, cl1, cl2},\n   m1 = tg[λ1, λ2][1, 1][uu];\n   m2 = tg[λ1, λ2][2, 1][uu];\n   cl1 = Map[PadRight[CoefficientList[#, uu], 3] &, m1, {2}];\n   cl2 = Map[PadRight[CoefficientList[#, uu], 5] &, m2, {2}];\n   {Table[cl1[[All, All, k]], {k, 1, 3}], Table[cl2[[All, All, k]], {k, 1, 5}]}\n];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*gl(3) weight multiplicities in the tensor product of two general reps λ1⊗λ2.\n  siteWeightMult[λ]: tally the gl(3) weight (J0[1],J0[2],J0[3]) of every GT pattern of λ.\n  wtMult: recover (n1,n2,n3) from (H1,H2) with N=total boxes, then convolve the two site tallies.\n  NB: Lookup's second argument, when itself a List, is treated as a list of *separate* keys\n  (not one list-valued key) — must wrap the composite weight key in Key[...] or Lookup silently\n  returns a per-component {0,0,0} instead of the single association value.*)\nClearAll[siteWeightMult,wtMult];\nsiteWeightMult[λ_]:=siteWeightMult[λ]=Counts[({J0[1][#],J0[2][#],J0[3][#]}&)/@ps[{λ}]];\nwtMult[λ1_,λ2_][H1_,H2_]:=Module[{Ntot=Total[λ1]+Total[λ2],n1,n2,n3,m1,m2},\n  n3=(Ntot-H1-2 H2)/3; n2=n3+H2; n1=n3+H1+H2;\n  If[!(IntegerQ[n1]&&IntegerQ[n2]&&IntegerQ[n3]),Return[0]];\n  m1=siteWeightMult[λ1]; m2=siteWeightMult[λ2];\n  Total[KeyValueMap[Function[{w,c}, c Lookup[m2,Key[{n1,n2,n3}-w],0]],m1]]\n];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*hard-assert sum-rule: Σ over all (H1,H2) of wtMult == dim[λ1] dim[λ2], for every test rep*)\nModule[{reps={{{2,1,0},{1,0,0}},{{2,0,0},{1,1,0}},{{1,1,0},{1,1,0}},{{2,1,0},{1,1,0}},{{2,2,0},{1,0,0}}},bad},\n  bad=Select[reps,Function[r,\n     Module[{Ntot=Total[r[[1]]]+Total[r[[2]]],d,tot},\n       d=dim[r[[1]]] dim[r[[2]]];\n       tot=Total@Flatten@Table[wtMult[r[[1]],r[[2]]][H1,H2],\n           {H1,-3 Ntot,3 Ntot},{H2,-3 Ntot,3 Ntot}];\n       tot=!=d]]];\n  If[bad=!={},Print[\"SUM-RULE FAIL: \",bad];Abort[]];\n  {\"all reps sum-rule OK\",\n   \"adjoint⊗fund @(H1,H2)=(0,0) mult\"->wtMult[{2,1,0},{1,0,0}][0,0]}\n]",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"352974\" data-output-id=\"420\" data-out-n=\"66\" data-sub-idx=\"1\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"21\" data-sub-start=\"1\" data-sub-end=\"11\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[66]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrpc57gh-mk8fv1i\" data-page-width-em=\"50\" data-latex-b64=\"XGxlZnRce1x0ZXh0e2FsbCByZXBzIHN1bS1ydWxlIE9LfSxcdGV4dHthZGpvaW50JFxvdGltZXMkZnVuZCBAKEgxLEgyKT0oMCwwKSBtdWx0fVx0byAwXHJpZ2h0XH0=\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">{</span><span class=\"mord text\"><span class=\"mord\">all reps sum-rule OK</span></span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord text\"><span class=\"mord\">adjoint</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">⊗</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mord\">fund @(H1,H2)=(0,0) mult</span></span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">→</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mord\">0</span><span class=\"mclose delimcenter\" style=\"top:0em;\">}</span></span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
      },
      {
       "data": "Out[66]= \\left\\{\\text{all reps sum-rule OK},\\text{adjoint$\\otimes$fund @(H1,H2)=(0,0) mult}\\to 0\\right\\}",
       "mime": "text/plain"
      }
     ],
     "id": "4f0d770b-0f6a-41a0-9dcf-16bad5b407e5"
    }
   ],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*guard on {2,1,0}⊗{2,1,0} (d=64) — a rep with genuine interior multiplicity on both sites*)\nModule[{λ1={2,1,0},λ2={2,1,0},Ntot,d,tot},\n  Ntot=Total[λ1]+Total[λ2]; d=dim[λ1] dim[λ2];\n  tot=Total@Flatten@Table[wtMult[λ1,λ2][H1,H2],{H1,-3 Ntot,3 Ntot},{H2,-3 Ntot,3 Ntot}];\n  If[tot!=d,Print[\"SUM-RULE FAIL: \",tot,\" != \",d];Abort[]];\n  {\"total weights\"->tot,\"dim\"->d}\n]",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"352974\" data-output-id=\"421\" data-out-n=\"67\" data-sub-idx=\"1\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"22\" data-sub-start=\"1\" data-sub-end=\"6\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[67]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrpc5bt8-aidj330\" data-page-width-em=\"50\" data-latex-b64=\"XGxlZnRce1x0ZXh0e3RvdGFsIHdlaWdodHN9XHRvIDY0LFx0ZXh0e2RpbX1cdG8gNjRccmlnaHRcfQ==\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">{</span><span class=\"mord text\"><span class=\"mord\">total weights</span></span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">→</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mord\">64</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord text\"><span class=\"mord\">dim</span></span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">→</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mord\">64</span><span class=\"mclose delimcenter\" style=\"top:0em;\">}</span></span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
      },
