      {
       "data": "Out[12]= \\left\\{\\left(u-\\frac{4}{3}\\right)\\,\\left(u-\\frac{8}{7}\\right),\\left(u-\\frac{1}{3}\\right)\\,\\left(u-\\frac{1}{7}\\right),\\left(0.720879750294453074533355301191+0.\\times 10^{-30}\\,\\mathrm{i}\\right)\\,u^2-\\left(1.06415582186324025288257211128+0.\\times 10^{-29}\\,\\mathrm{i}\\right)\\,u\\right\\}",
