       "data": "Out[65]//TableForm= \\begin{pmatrix}0 & 0 & 0.\\times 10^{-26}\\\\1 & 0 & 0.\\times 10^{-26}\\\\1 & 1 & 0.\\times 10^{-26}\\\\2 & 0 & 0.\\times 10^{-26}\\\\2 & 1 & 0.\\times 10^{-26}\\\\3 & 0 & 0.\\times 10^{-26}\\end{pmatrix}",
       "mime": "text/plain"
