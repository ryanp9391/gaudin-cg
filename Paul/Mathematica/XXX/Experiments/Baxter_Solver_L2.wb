      {
       "data": "Out[64]//TableForm= \\begin{pmatrix}0 & 0 & 0.\\times 10^{-26}\\\\1 & 0 & 0.\\times 10^{-26}\\\\1 & 1 & 0.\\times 10^{-27}\\\\2 & 0 & 0.\\times 10^{-26}\\end{pmatrix}",
