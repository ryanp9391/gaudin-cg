       "data": "Out[16]= \\begin{matrix}\\left\\{0,\\text{max|deg M+1,M+2 coeff|}\\to 0.\\times 10^{-29}\\right\\}\\\\\\left\\{1,\\text{max|deg M+1,M+2 coeff|}\\to 0.\\times 10^{-29}\\right\\}\\\\\\left\\{2,\\text{max|deg M+1,M+2 coeff|}\\to 0.\\times 10^{-29}\\right\\}\\end{matrix}",
