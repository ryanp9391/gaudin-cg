      {
       "data": "Out[76]= \\left\\{\\text{tau3 closed form == tg[3,1] ?},\\left\\{1,1\\right\\}\\to \\mathrm{True},\\left\\{2,1\\right\\}\\to \\mathrm{True},\\left\\{1,2\\right\\}\\to \\mathrm{True}\\right\\}",
