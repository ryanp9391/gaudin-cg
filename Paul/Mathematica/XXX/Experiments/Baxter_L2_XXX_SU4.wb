      {
       "data": "Out[149]= \\begin{array}{|c|c|c|c|c|c|c|}\\hline\\text{log10 maxResid @(2,2)} & \\text{\\{1,C2\\}} & \\text{\\{1,C2,C2\\^{}2\\}} & \\text{\\{1,C2,C2\\^{}2,C2\\^{}3\\}} & \\text{\\{1,C2,C2\\^{}2,C4\\}} & \\text{\\{1,C2,C2\\^{}2,C4,C2\\^{}3\\}} & \\text{\\{1,C2,C2\\^{}2,C4,C4\\^{}2\\}}\\\\\\hline\\text{Lam2 u\\^{}0} & \\frac{7}{5} & \\frac{11}{10} & \\frac{9}{10} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate}\\\\\\hline\\text{Lam2 u\\^{}1} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate}\\\\\\hline\\text{Lam2 u\\^{}2} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate}\\\\\\hline\\text{Lam2 u\\^{}3} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate}\\\\\\hline\\text{Lam2 u\\^{}4} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate} & \\mathrm{Indeterminate}\\\\\\hline\\text{-} & \\text{-} & \\text{-} & \\text{-} & \\text{-} & \\text{-} & \\text{-}\\\\\\hline\\text{Lam3 u\\^{… [latex truncated: 2428 chars total]",
