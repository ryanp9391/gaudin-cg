      {
       "data": "Out[166]= \\left\\{\\text{Lam3pred (affine in C2mu, no C4) VERIFIED full sweep, worst}\\to 0.\\times 10^{-22},\\text{Lam2pred (u\\^{}0 carries +1/8 C2mu\\^{}2 -1/4 C4mu) VERIFIED full sweep, worst}\\to 0.\\times 10^{-23}\\right\\}",
