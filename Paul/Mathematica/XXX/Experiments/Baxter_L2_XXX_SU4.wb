      {
       "data": "Out[92]= \\begin{matrix}\\left\\{\\begin{pmatrix}1 & 0 & 0 & 0\\\\1 & 0 & 0 & 0\\end{pmatrix},\\text{nstates}\\to 16,\\text{worstTQ}\\to 0,\\text{worstCasoratian}\\to 0\\right\\}\\\\\\left\\{\\begin{pmatrix}1 & 0 & 0 & 0\\\\1 & 1 & 1 & 0\\end{pmatrix},\\text{nstates}\\to 16,\\text{worstTQ}\\to 0,\\text{worstCasoratian}\\to 0\\right\\}\\\\\\left\\{\\begin{pmatrix}1 & 1 & 0 & 0\\\\1 & 0 & 0 & 0\\end{pmatrix},\\text{nstates}\\to 24,\\text{worstTQ}\\to 0,\\text{worstCasoratian}\\to 0\\right\\}\\\\\\left\\{\\begin{pmatrix}1 & 1 & 0 & 0\\\\1 & 1 & 0 & 0\\end{pmatrix},\\text{nstates}\\to 36,\\text{worstTQ}\\to 0,\\text{worstCasoratian}\\to 0\\right\\}\\\\\\left\\{\\begin{pmatrix}2 & 1 & 1 & 0\\\\1 & 0 & 0 & 0\\end{pmatrix},\\text{nstates}\\to 60,\\text{worstTQ}\\to 0,\\text{worstCasoratian}\\to 0\\right\\}\\end{matrix}",
