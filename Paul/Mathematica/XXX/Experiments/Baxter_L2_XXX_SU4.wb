  },
  {
   "kind": 2,
   "value": "t1vac=L1[u]+L2[u]+L3[u]+L4[u];\nt2vac=L4[u]L3[u-h]+L4[u]L2[u-h]+L4[u]L1[u-h]+L3[u]L2[u-h]+L3[u]L1[u-h]+L2[u]L1[u-h];\nt3vac=L4[u]L3[u-h]L2[u-2h]+L4[u]L3[u-h]L1[u-2h]+L4[u]L2[u-h]L1[u-2h]+L3[u]L2[u-h]L1[u-2h];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
