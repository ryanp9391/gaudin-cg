      {
       "data": "Out[216]= \\left\\{\\left\\{36,36\\right\\},\\left\\{36,36\\right\\},\\text{C3site11}\\to 18,\\text{C4site11}\\to 54,\\text{C2site11}\\to \\mathrm{Csite}\\left(\\left\\{1,1,0,0\\right\\}\\right)\\right\\}",
