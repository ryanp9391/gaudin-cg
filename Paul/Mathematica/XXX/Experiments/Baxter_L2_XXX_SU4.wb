      {
       "data": "Out[92]//TableForm= \\begin{pmatrix}\\text{C2[S,P]} & 2\\,P^2+4\\,P+2\\,S^2+4\\,S\\\\\\text{C3[S,P]} & 2\\,P^3+8\\,P^2+8\\,P+2\\,S^3+8\\,S^2+8\\,S\\\\\\text{C4[S,P]} & 2\\,P^4+12\\,P^3+24\\,P^2+16\\,P+2\\,S^4+12\\,S^3+24\\,S^2+16\\,S\\end{pmatrix}",
