      {
       "data": "Out[123]= \\left\\{\\left\\{\\text{j}\\to 0,\\text{fit}\\to 0.30352429540663584347487201\\,x-3.7928443631265547617782299,\\text{maxResidual}\\to 3.0279243439949184754414068\\right\\},\\left\\{\\text{j}\\to 1,\\text{fit}\\to -0.086862943083382048147951321\\,x-5.4342299389862763407961899,\\text{maxResidual}\\to 1.2544507626082797470372535\\right\\},\\left\\{\\text{j}\\to 2,\\text{fit}\\to 4.0000000000000000000000000-1.3704477937440532423380956\\times 10^{-40}\\,x,\\text{maxResidual}\\to 0.\\times 10^{-26}\\right\\}\\right\\}",
