       "data": "Out[30]= \\left\\{\\frac{1}{3},\\frac{1}{7},1,0.3604398751472265372666776505955500912940811467928913386732181476418264+0.9327824485933747164848359820708679294577272928322431080055758094332927\\,\\mathrm{i},0.5088673809904998281633213722670686199090972690844597081081963623607767+0.8608449271290790931886443936161642458151427736784766273900288346856365\\,\\mathrm{i},0.5332578805895993725958323450931242953616086277451232771563871100742240+0.8459527367347945264833816184531425898622008061320289106990227397003151\\,\\mathrm{i},0.5386112130224389404516227590233027415979977202782689890158126717079610+0.8425544262577325640105911776956468561759145278669222827514041597283890\\,\\mathrm{i},1.941176349749764678477454126979045748162784763900743312953614291784788+3.482134538714980900167453171835821621310985400509670928846031543547633\\,\\mathrm{i},-3.14187658347867932923655848463049838194769477078940775779086802465515+5.080249095348404597516787606618709153079196034458211390527893684654161\\,\\mathrm{i},-3.98252798874963316592299781129581668832068933495887466154737555184985-0.18137636385542430646201337934233180628007708248758196636019445172909\\,\\mathrm{i},-0.44667600238174743327740269262590055091804208386687646930974953443… [latex truncated: 1296 chars total]",
