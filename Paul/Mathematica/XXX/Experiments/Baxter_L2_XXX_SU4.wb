  {
   "kind": 2,
   "value": "(*monodromy with no twist and diagonal twist*)\nClearAll[T,Tg];\nT[λ1_,λ2_][i_,j_][u_]:=Sum[KroneckerProduct[L[λ1][i,ii][u-θ1],L[λ2][ii,j][u-θ2]],{ii,4}];\nTg[λ1_,λ2_][i_,j_][u_]:= z[i] T[λ1,λ2][i,j][u];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "{Abs[χ1 - Total[{z[1],z[2],z[3],z[4]}]], Min[Abs[Subtract @@@ Subsets[{z[1],z[2],z[3],z[4]}, {2}]]]}",
   "languageId": "wolfram",
