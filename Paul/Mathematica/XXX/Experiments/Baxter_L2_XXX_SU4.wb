       "data": "Out[148]= \\begin{matrix}\\left\\{1,1,\\text{nMu}\\to 3,\\left\\{0\\to \\left\\{\\text{\\{1,C2,C2\\^{}2\\}},\\text{coeffs}\\to \\left\\{16.2630385487528344671201814,-4.47619047619047619047619048,0.25\\right\\},\\text{resid}\\to 0.\\times 10^{-24}\\right\\},1\\to \\left\\{\\text{\\{1,C2\\}},\\text{coeffs}\\to \\left\\{9.1972789115646258503401361,-2.4761904761904761904761905\\right\\},\\text{resid}\\to 0.\\times 10^{-24}\\right\\},2\\to \\left\\{\\text{\\{1,C2\\}},\\text{coeffs}\\to \\left\\{33.0748299319727891156462585,1.00000000000000000000000000\\right\\},\\text{resid}\\to 0.\\times 10^{-25}\\right\\},3\\to \\left\\{\\text{\\{1,C2\\}},\\text{coeffs}\\to \\left\\{-29.7142857142857142857142857,0\\right\\},\\text{resid}\\to 0.\\times 10^{-25}\\right\\},4\\to \\left\\{\\text{\\{1,C2\\}},\\text{coeffs}\\to \\left\\{6.00000000000000000000000000,0\\right\\},\\text{resid}\\to 0.\\times 10^{-26}\\right\\}\\right\\}\\right\\}\\\\\\left\\{2,1,\\text{nMu}\\to 3,\\left\\{0\\to \\left\\{\\text{\\{1,C2,C2\\^{}2\\}},\\text{coeffs}\\to \\left\\{92.6235827664399092970521542,-9.90476190476190476190476190,0.250000000000000000000000000\\right\\},\\text{resid}\\to 0.\\times 10^{-24}\\right\\},1\\to \\left\\{\\text{\\{1,C2\\}},\\text{coeffs}\\to \\left\\{34.3605442176870748299319728,-2.97619047619047619047619048\\right\\},\\text{resid}\\to 0.\\time… [latex truncated: 3200 chars total]",
