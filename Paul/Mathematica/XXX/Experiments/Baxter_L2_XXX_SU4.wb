      {
       "data": "Out[154]= \\begin{matrix}\\text{=== Lam3 ===}\\\\\\begin{matrix}\\left\\{1,1,\\text{Lam3 u\\^{}k -> \\{A\\_k,B\\_k\\}(basis 1,C2mu)}\\to \\left\\{0\\to \\left\\{\\frac{23320}{9261},\\frac{110}{441}\\right\\},1\\to \\left\\{-\\frac{103952}{3087},-\\frac{1168}{441}\\right\\},2\\to \\left\\{\\frac{148522}{1029},\\frac{6001}{882}\\right\\},3\\to \\left\\{-\\frac{2273512}{9261},-\\frac{73}{21}\\right\\},4\\to \\left\\{\\frac{22954}{147},\\frac{1}{2}\\right\\},5\\to \\left\\{-\\frac{292}{7},0\\right\\},6\\to \\left\\{4,0\\right\\}\\right\\}\\right\\}\\\\\\left\\{2,1,\\text{Lam3 u\\^{}k -> \\{A\\_k,B\\_k\\}(basis 1,C2mu)}\\to \\left\\{0\\to \\left\\{\\frac{286}{189},\\frac{143}{441}\\right\\},1\\to \\left\\{-\\frac{81119}{3087},-\\frac{431}{126}\\right\\},2\\to \\left\\{\\frac{22285}{147},\\frac{7597}{882}\\right\\},3\\to \\left\\{-\\frac{2962669}{9261},-\\frac{167}{42}\\right\\},4\\to \\left\\{\\frac{29065}{147},\\frac{1}{2}\\right\\},5\\to \\left\\{-\\frac{334}{7},0\\right\\},6\\to \\left\\{4,0\\right\\}\\right\\}\\right\\}\\\\\\left\\{1,2,\\text{Lam3 u\\^{}k -> \\{A\\_k,B\\_k\\}(basis 1,C2mu)}\\to \\left\\{0\\to \\left\\{\\frac{5510}{3087},\\frac{145}{441}\\right\\},1\\to \\left\\{-\\frac{271109}{9261},-\\frac{1019}{294}\\right\\},2\\to \\left\\{\\frac{494405}{3087},\\frac{7681}{882}\\right\\},3\\to \\left\\{-\\frac{3022141}{9261},-\\frac{167}{42}\\right\\},4\\to… [latex truncated: 3396 chars total]",
