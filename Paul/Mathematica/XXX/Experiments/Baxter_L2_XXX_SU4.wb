       "data": "Out[28]= \\left\\{\\frac{1}{3},\\frac{1}{7},1,0.360439875147226537266677650596+0.932782448593374716484835982071\\,\\mathrm{i},0.508867380990499828163321372267+0.860844927129079093188644393616\\,\\mathrm{i},0.533257880589599372595832345093+0.845952736734794526483381618453\\,\\mathrm{i},0.538611213022438940451622759023+0.842554426257732564010591177696\\,\\mathrm{i},1.94117634974976467847745412698+3.48213453871498090016745317184\\,\\mathrm{i},-3.1418765834786793292365584846+5.08024909534840459751678760662\\,\\mathrm{i},-3.9825279887496331659229978113-0.1813763638554243064620133793\\,\\mathrm{i},-0.44667600238174743327740269263-0.89469578567033675355064601688\\,\\mathrm{i}\\right\\}",
