      {
       "data": "Out[69]= \\begin{array}{|c|c|c|c|c|c|c|}\\hline\\text{mu} & \\text{dim} & \\text{deg q\\_k} & \\text{Cas2} & \\text{Cas4} & \\text{time (s)} & \\text{solves?}\\\\\\hline10,10,0,0 & 1716 & 0,1,12,13 & 240 & 34560 & \\text{0.0367} & \\mathrm{True}\\\\\\hline10,9,1,0 & 4719 & 0,2,11,13 & 220 & 29740 & \\text{0.0312} & \\mathrm{True}\\\\\\hline10,8,2,0 & 6825 & 0,3,10,13 & 204 & 26172 & \\text{0.0238} & \\mathrm{True}\\\\\\hline10,7,3,0 & 7020 & 0,4,9,13 & 192 & 23664 & \\text{0.0229} & \\mathrm{True}\\\\\\hline10,6,4,0 & 5200 & 0,5,8,13 & 184 & 22072 & \\text{0.0224} & \\mathrm{True}\\\\\\hline10,5,5,0 & 1911 & 0,6,7,13 & 180 & 21300 & \\text{0.0323} & \\mathrm{True}\\\\\\hline9,9,1,1 & 825 & 1,2,11,12 & 196 & 23428 & \\text{0.0240} & \\mathrm{True}\\\\\\hline9,8,2,1 & 2079 & 1,3,10,12 & 180 & 19860 & \\text{0.0311} & \\mathrm{True}\\\\\\hline9,7,3,1 & 2640 & 1,4,9,12 & 168 & 17352 & \\text{0.0224} & \\mathrm{True}\\\\\\hline9,6,4,1 & 2156 & 1,5,8,12 & 160 & 15760 & \\text{0.0211} & \\mathrm{True}\\\\\\hline9,5,5,1 & 825 & 1,6,7,12 & 156 & 14988 & \\text{0.0233} & \\mathrm{True}\\\\\\hline8,8,2,2 & 336 & 2,3,10,11 & 160 & 15040 & \\text{0.0232} & \\mathrm{True}\\\\\\hline8,7,3,2 & 735 & 2,4,9,11 & 148 & 12532 & \\text{0.0203} & \\mathrm{True}\\\\\\hline8,6,4,2 & 729 & 2… [latex truncated: 1804 chars total]",
