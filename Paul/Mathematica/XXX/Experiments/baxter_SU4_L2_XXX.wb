      {
       "data": "Out[14]= \\frac{-a\\left(1\\right)+a\\left(2\\right)+4\\,h\\,P+4\\,h\\,S+12\\,h+8\\,\\theta1+8\\,\\theta2}{u}+\\frac{a\\left(2\\right)\\,h\\,M\\left(1\\right)-a\\left(1\\right)\\,h\\,P+a\\left(2\\right)\\,h\\,P-a\\left(1\\right)\\,h\\,S+a\\left(2\\right)\\,h\\,S+2\\,a\\left(2\\right)\\,h-a\\left(1\\right)\\,\\theta1+2\\,a\\left(2\\right)\\,\\theta1-a\\left(1\\right)\\,\\theta2+2\\,a\\left(2\\right)\\,\\theta2-b\\left(1\\right)+b\\left(2\\right)-b\\left(3\\right)+6\\,h^2\\,M\\left(1\\right)\\,P+6\\,h^2\\,M\\left(1\\right)\\,S+12\\,h^2\\,M\\left(1\\right)+3\\,h^2\\,P^2+4\\,h^2\\,P\\,S+19\\,h^2\\,P+3\\,h^2\\,S^2+19\\,h^2\\,S+22\\,h^2+34\\,h\\,\\theta1+34\\,h\\,\\theta2+12\\,h\\,\\theta1\\,M\\left(1\\right)+12\\,h\\,\\theta2\\,M\\left(1\\right)+10\\,h\\,\\theta1\\,P+12\\,h\\,\\theta2\\,P+12\\,h\\,\\theta1\\,S+10\\,h\\,\\theta2\\,S+14\\,\\theta1^2+20\\,\\theta1\\,\\theta2+14\\,\\theta2^2}{u^2}+\\mathcal{O}\\left(\\left(\\frac{1}{u}\\right)^3\\right)",
