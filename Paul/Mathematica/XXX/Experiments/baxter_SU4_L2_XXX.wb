      {
       "data": "Out[35]= h^2\\,m1^2+3\\,h^2\\,m1+h^2\\,m2^2+h^2\\,m2+h^2\\,m3^2-h^2\\,m3+h^2\\,m4^2-3\\,h^2\\,m4-h^2\\,P^2+4\\,h^2\\,P\\,S+3\\,h^2\\,P-h^2\\,S^2+3\\,h^2\\,S+6\\,h^2+18\\,h\\,\\theta1+18\\,h\\,\\theta2+12\\,h\\,\\theta1\\,P+6\\,h\\,\\theta2\\,P+6\\,h\\,\\theta1\\,S+12\\,h\\,\\theta2\\,S+6\\,\\theta1^2+24\\,\\theta1\\,\\theta2+6\\,\\theta2^2",
       "mime": "text/plain"
