      {
       "data": "Out[81]= Q\\left(u\\right)\\,\\left(C2^2+2\\,C2\\,P+2\\,C2\\,S+2\\,C2-2\\,C4+4\\,P^3+12\\,P^2\\,S+20\\,P^2+12\\,P\\,S^2+40\\,P\\,S+24\\,P+4\\,S^3+20\\,S^2+24\\,S\\right)-4\\,Q''\\left(u\\right)\\,\\left(C2\\,\\theta1\\,\\theta2+C2\\,u^2-C2\\,\\theta1\\,u-C2\\,\\theta2\\,u-2\\,\\theta1^2\\,P^2-2\\,\\theta1\\,\\theta2\\,P^2-4\\,P^2\\,u^2+6\\,\\theta1\\,P^2\\,u+2\\,\\theta2\\,P^2\\,u-2\\,\\theta1^2\\,P-4\\,\\theta1\\,\\theta2\\,P-8\\,\\theta1\\,\\theta2\\,P\\,S-8\\,P\\,S\\,u^2+8\\,\\theta1\\,P\\,S\\,u+8\\,\\theta2\\,P\\,S\\,u-6\\,P\\,u^2+8\\,\\theta1\\,P\\,u+4\\,\\theta2\\,P\\,u-2\\,\\theta1\\,\\theta2\\,S^2-2\\,\\theta2^2\\,S^2-4\\,S^2\\,u^2+2\\,\\theta1\\,S^2\\,u+6\\,\\theta2\\,S^2\\,u-4\\,\\theta1\\,\\theta2\\,S-2\\,\\theta2^2\\,S-6\\,S\\,u^2+4\\,\\theta1\\,S\\,u+8\\,\\theta2\\,S\\,u\\right)+4\\,\\left(C2-2\\,P^2-4\\,P\\,S-4\\,P-2\\,S^2-4\\,S\\right)\\,Q'\\left(u\\right)\\,\\left(-\\theta1-\\theta2-\\theta1\\,P+P\\,u-\\theta2\\,S+S\\,u+2\\,u\\right)-16\\,Q^{\\left(3\\right)}\\left(u\\right)\\,\\left(u-\\theta1\\right)\\,\\left(u-\\theta2\\right)\\,\\left(-\\theta1\\,P+P\\,u-\\theta2\\,S+S\\,u\\right)+8\\,Q^{\\left(4\\right)}\\left(u\\right)\\,\\left(u-\\theta1\\right)^2\\,\\left(u-\\theta2\\right)^2",
       "mime": "text/plain"
      }
