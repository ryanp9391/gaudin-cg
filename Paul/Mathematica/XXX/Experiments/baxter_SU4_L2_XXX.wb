       "data": "Out[27]= \\begin{matrix}a\\left(1\\right)\\to -2\\,\\left(h\\,P+h\\,S+2\\,\\theta1+2\\,\\theta2\\right)\\\\a\\left(2\\right)\\to -6\\,\\left(h\\,P+h\\,S+2\\,h+2\\,\\theta1+2\\,\\theta2\\right)\\\\b\\left(1\\right)\\to \\frac{1}{2}\\,\\left(b\\left(2\\right)+h^2\\,\\left(-P^2\\right)-4\\,h^2\\,P\\,S-7\\,h^2\\,P-h^2\\,S^2-7\\,h^2\\,S-6\\,h^2-18\\,h\\,\\theta1-18\\,h\\,\\theta2-8\\,h\\,\\theta1\\,P-6\\,h\\,\\theta2\\,P-6\\,h\\,\\theta1\\,S-8\\,h\\,\\theta2\\,S-6\\,\\theta1^2-16\\,\\theta1\\,\\theta2-6\\,\\theta2^2\\right)\\\\c\\left(2\\right)\\to \\frac{1}{2}\\,\\left(-b\\left(2\\right)\\,h\\,P-b\\left(2\\right)\\,h\\,S-2\\,b\\left(2\\right)\\,h-2\\,b\\left(2\\right)\\,\\theta1-2\\,b\\left(2\\right)\\,\\theta2+h^3\\,P^3+5\\,h^3\\,P^2\\,S+7\\,h^3\\,P^2+5\\,h^3\\,P\\,S^2+22\\,h^3\\,P\\,S+18\\,h^3\\,P+h^3\\,S^3+7\\,h^3\\,S^2+18\\,h^3\\,S+12\\,h^3+36\\,h^2\\,\\theta1+36\\,h^2\\,\\theta2+10\\,h^2\\,\\theta1\\,P^2+8\\,h^2\\,\\theta2\\,P^2+40\\,h^2\\,\\theta1\\,P+32\\,h^2\\,\\theta2\\,P+18\\,h^2\\,\\theta1\\,P\\,S+18\\,h^2\\,\\theta2\\,P\\,S+8\\,h^2\\,\\theta1\\,S^2+10\\,h^2\\,\\theta2\\,S^2+32\\,h^2\\,\\theta1\\,S+40\\,h^2\\,\\theta2\\,S+36\\,h\\,\\theta1^2+72\\,h\\,\\theta1\\,\\theta2+36\\,h\\,\\theta2^2+18\\,h\\,\\theta1^2\\,P+36\\,h\\,\\theta1\\,\\theta2\\,P+18\\,h\\,\\theta2^2\\,P+18\\,h\\,\\theta1^2\\,S+36\\,h\\,\\theta1\\,\\theta2\\,S+18\\,h\\,\\theta2^2\\,S+12\\,\\theta1^3+36\\,\\theta1^2\\,\\theta2+36\\,\\theta1\\… [latex truncated: 1522 chars total]",
