   "value": "ClearAll[trat,tguess];\ntrat[S_,P_]:=t[{S,S,0,0},{P,P,0,0}][3,1][u]/trivfactor[S,P]//Factor;\ntguess[S_,P_]:=(4u^2-4u(θ1+θ2)+4 θ1 θ2-2h P u - 2 h S u-8 h u +2h θ1 P +2 h θ2 S+4 h θ1 + 4 h θ2-h^2(-8 + 3 S + 3 P)) IdentityMatrix[dim[{S,S,0,0}]dim[{P,P,0,0}]]+1/2 h^2 C2op[{S,S,0,0},{P,P,0,0}];",
