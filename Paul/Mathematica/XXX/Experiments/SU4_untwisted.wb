{
 "cells": [
  {
   "kind": 2,
   "value": "(*su(4) generators*)\nps[rep_] := ps[rep] = Block[{res = (Prepend[rep, #] & /@ (Tuples[Table[Range[rep[[1, i + 1]], rep[[1, i]]], {i, 1, Length[rep[[1]]] - 1}]]))}, If[Length[res[[1, 1]]] == 1, Reverse@Sort@res, Reverse@Sort@Flatten[ps /@ res, 1]]];\ndim[rep_] := dim[rep] = Length[ps[{rep}]];\nJ0[k_][pat_] := J0[k][pat] = Sum[pat[[k, i]], {i, 1, k}] - Sum[pat[[k - 1, i]], {i, 1, k - 1}];\nJp[k_][pat_] := Jp[k][pat] = -Sum[Product[pat[[k, i]] - i - pat[[k + 1, j]] + j, {j, Range[k + 1]}]/Product[pat[[k, i]] - i - pat[[k, j]] + j, {j, Complement[Range[k], {i}]}] v[ReplacePart[pat, {k, i} -> pat[[k, i]] + 1]], {i, 1, k}];\nJm[k_][pat_] := Jm[k][pat] = Sum[Product[pat[[k, i]] - i - pat[[k - 1, j]] + j, {j, Range[k - 1]}]/Product[pat[[k, i]] - i - pat[[k, j]] + j, {j, Complement[Range[k], {i}]}] v[ReplacePart[pat, {k, i} -> pat[[k, i]] - 1]], {i, 1, k}];\nJJ[k_, l_, rep_] := JJ[k, l, rep] = Which[k == l, DiagonalMatrix[J0[k] /@ ps[{rep}]], l == k + 1, Transpose[Table[Coefficient[Jp[k][ps[{rep}][[i]]], v[#]] & /@ ps[{rep}], {i, 1, Length[ps[{rep}]]}]], l == k - 1, Transpose[Table[Coefficient[Jm[l][ps[{rep}][[i]]], v[#]] & /@ ps[{rep}], {i, 1, Length[ps[{rep}]]}]], l > k + 1, JJ[k, k + 1, rep] . JJ[k + 1, l, rep] - JJ[k + 1, l, rep] . JJ[k, k + 1, rep], l < k - 1, JJ[k, k - 1, rep] . JJ[k - 1, l, rep] - JJ[k - 1, l, rep] . JJ[k, k - 1, rep]];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "ClearAll[Ee,id,EE,idd];\nEe[λ_][i_,j_]:=JJ[i,j,λ];\nid[λ_]:=IdentityMatrix[dim[λ]];\nidd[λ1_,λ2_]:=KroneckerProduct[id[λ1],id[λ2]];\nEE[λ1_,λ2_][i_,j_]:=KroneckerProduct[Ee[λ1][i,j],id[λ2]]+KroneckerProduct[id[λ1],Ee[λ2][i,j]];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "ClearAll[C1op,C2op,C3op,C4op];\nC1op[λ1_, λ2_] := C1op[λ1, λ2] = Sum[EE[λ1, λ2][a, a], {a, 4}];\nC2op[λ1_, λ2_] := C2op[λ1, λ2] = Sum[EE[λ1, λ2][a, b] . EE[λ1, λ2][b, a], {a, 4}, {b, 4}];\nC3op[λ1_, λ2_] := C3op[λ1, λ2] = Sum[EE[λ1, λ2][a, b] . EE[λ1, λ2][b, c] . EE[λ1, λ2][c, a], {a, 4}, {b, 4}, {c, 4}];\nC4op[λ1_, λ2_] := C4op[λ1, λ2] = Sum[EE[λ1, λ2][a, b] . EE[λ1, λ2][b, c] . EE[λ1, λ2][c, d] . EE[λ1, λ2][d, a], {a, 4}, {b, 4}, {c, 4}, {d, 4}];\n",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*Lax operator for a general gl(4) rep λ={λ1,λ2,λ3,λ4} at the site*)\nClearAll[L];\nL[λ_][i_,j_][u_]:=IdentityMatrix[dim[λ]] u KroneckerDelta[i,j] - h JJ[j,i,λ];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*monodromy with no twist and diagonal twist*)\nClearAll[T,Tg];\nT[λ1_,λ2_][i_,j_][u_]:=Sum[KroneckerProduct[L[λ1][i,ii][u-θ1],L[λ2][ii,j][u-θ2]],{ii,4}];\nTg[λ1_,λ2_][i_,j_][u_]:= z[i] T[λ1,λ2][i,j][u];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*quantum minors (q-determinants) of the monodromy matrix*)\nClearAll[qmin,qming];\nqmin[λ1_, λ2_][II_List, JJ_List][u_] := qmin[λ1, λ2][II, JJ][u] = Sum[Signature[σ] Dot @@ Table[T[λ1, λ2][II[[σ[[k]]]], JJ[[k]]][u - (k - 1) h], {k, Length[II]}], {σ, Permutations[Range[Length[II]]]}];\nqming[λ1_, λ2_][II_List, JJ_List][u_] := qming[λ1, λ2][II, JJ][u] = Sum[Signature[σ] Dot @@ Table[Tg[λ1, λ2][II[[σ[[k]]]], JJ[[k]]][u - (k - 1) h], {k, Length[II]}], {σ, Permutations[Range[Length[II]]]}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*transfer matrices with diagonal twist*)\nClearAll[t];\nt[λ1_,λ2_][a_,1][u_]:= Total[qmin[λ1, λ2][#, #][u] & /@ Subsets[{1, 2, 3, 4}, {a}]]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "L1[u_]=(u-θ1- h S)(u-θ2-h P);\nL2[u_]=(u-θ1- h S)(u-θ2-h P);\nL3[u_]=(u- θ1)(u- θ2);\nL4[u_]=(u- θ1)(u- θ2);",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "L1[u]+L2[u]+L3[u]+L4[u]//Simplify;\n%-((4u^2 - 4u(θ1+θ2)- u (2h P+ 2h S)+4 θ1 θ2 + 2 h S θ2+h 2  P θ1+  2h^2 P S))//Simplify//Expand//Collect[#,u]&",
   "languageId": "wolfram",
   "outputs": [
