      {
       "data": "Out[38]= \\begin{pmatrix}1 & \\left\\{0,0\\right\\}\\\\2 & \\left\\{0,0,0\\right\\}\\\\3 & \\left\\{0,0,0,0\\right\\}\\\\4 & \\left\\{0,0,0,0,0\\right\\}\\end{pmatrix}",
