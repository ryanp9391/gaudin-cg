      {
       "data": "Out[27]= \\left\\{c\\left(1\\right)\\left(1\\right)\\to \\zeta ,c\\left(2\\right)\\left(1\\right)\\to 2\\,\\zeta ,c\\left(2\\right)\\left(2\\right)\\to \\zeta ^2,c\\left(3\\right)\\left(1\\right)\\to 3\\,\\zeta ,c\\left(3\\right)\\left(2\\right)\\to 3\\,\\zeta ^2,c\\left(3\\right)\\left(3\\right)\\to \\zeta ^3,c\\left(4\\right)\\left(1\\right)\\to 4\\,\\zeta ,c\\left(4\\right)\\left(2\\right)\\to 6\\,\\zeta ^2,c\\left(4\\right)\\left(3\\right)\\to 4\\,\\zeta ^3,c\\left(4\\right)\\left(4\\right)\\to \\zeta ^4,c\\left(5\\right)\\left(1\\right)\\to 5\\,\\zeta ,c\\left(5\\right)\\left(2\\right)\\to 10\\,\\zeta ^2,c\\left(5\\right)\\left(3\\right)\\to 10\\,\\zeta ^3,c\\left(5\\right)\\left(4\\right)\\to 5\\,\\zeta ^4,c\\left(5\\right)\\left(5\\right)\\to \\zeta ^5\\right\\}",
