span></span></span><span class=\"mclose\">∣</span><span class=\"mspace\" style=\"margin-right:-0.1667em;\"></span><span class=\"mclose\">⟩</span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
      },
      {
       "data": "Out[111]= \\langle\\!\\lvert \\text{(2,1), $\\zeta$=-w}\\to \\left\\{0\\right\\},\\text{(2,1), $\\zeta$=w}\\to \\left\\{0,-2\\,w,-\\frac{w^3}{3}\\right\\},\\text{(2,1), $\\zeta$=1/w}\\to \\left\\{0,-\\frac{w^2+1}{w},\\frac{w^4-1}{2\\,w^2},-\\frac{w^6+1}{6\\,w^3},\\frac{w^8-1}{24\\,w^4}\\right\\},\\text{(2,1), $\\zeta$=-1/w}\\to \\left\\{0,\\frac{1}{w}-w,\\frac{w^4-1}{2\\,w^2},-\\frac{w^6-1}{6\\,w^3},\\frac{w^8-1}{24\\,w^4}\\right\\},\\text{(1,2), $\\zeta$=-w}\\to \\left\\{0,-w,\\frac{w^2}{2},-\\frac{w^3}{6},\\frac{w^4}{24}\\right\\},\\text{(1,2), $\\zeta$=w}\\to \\left\\{0,-w,\\frac{w^2}{2},-\\frac{w^3}{6},\\frac{w^4}{24}\\right\\},\\text{(1,2), $\\zeta$=1/w}\\to \\left\\{0,-w,\\frac{w^2}{2},-\\frac{w^3}{6},\\frac{w^4}{24}\\right\\},\\text{(1,2), $\\zeta$=-1/w}\\to \\left\\{0,-w,\\frac{w^2}{2},-\\frac{w^3}{6},\\frac{w^4}{24}\\right\\}\\rvert\\!\\rangle",
       "mime": "text/plain"
      }
     ],
     "id": "d1c88d0c-5fcc-4ad5-b3b1-06aaebe59e88"
