2.8,332.5,228.5,527.5c55.7,195,92.8,416.5,111.5,664.5\nc11.3,139.3,17,290.7,17,454c0,28,1.7,43,3.3,45l0,1809\nc-3,4,-3.3,16.7,-3.3,38c0,162,-5.7,313.7,-17,455c-18.7,248,-55.8,469.3,-111.5,664\nc-55.7,194.7,-131.8,370.3,-228.5,527c-20.7,34.7,-41.7,66.3,-63,95c-2,3.3,-4,7,-6,11\nc0,7.3,5.7,11,17,11c0,0,11,0,11,0c9.3,0,14.3,-0.3,15,-1c5.3,-5.3,10.3,-11,15,-17\nc242.7,-294.7,395.3,-681.7,458,-1161c21.3,-164.7,33.3,-350.7,36,-558\nl0,-1944c-2,-159.3,-10,-310.7,-24,-454c-53.3,-528,-210,-949.7,\n-470,-1265c-4.7,-6,-9.7,-11.7,-15,-17c-0.7,-0.7,-6.7,-1,-18,-1z\"/></svg></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:2.45em;\"><span></span></span></span></span></span></span></span><span class=\"mclose\"><span class=\"delimsizing mult\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:2.95em;\"><span style=\"top:-1.6em;\"><span class=\"pstrut\" style=\"height:3.15em;\"></span><span class=\"delimsizinginner delim-size4\"><span>⎭</span></span></span><span style=\"top:-1.592em;\"><span class=\"pstrut\" style=\"height:3.15em;\"></span><span style=\"height:0.916em;width:0.8889em;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"0.8889em\" height=\"0.916em\" style=\"width:0.8889em\" viewBox=\"0 0 888.89 916\" preserveAspectRatio=\"xMinYMin\"><path d=\"M384 0 H504 V916 H384z M384 0 H504 V916 H384z\"/></svg></span></span><span style=\"top:-3.15em;\"><span class=\"pstrut\" style=\"height:3.15em;\"></span><span class=\"delimsizinginner delim-size4\"><span>⎬</span></span></span><span style=\"top:-4.292em;\"><span class=\"pstrut\" style=\"height:3.15em;\"></span><span style=\"height:0.916em;width:0.8889em;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"0.8889em\" height=\"0.916em\" style=\"width:0.8889em\" viewBox=\"0 0 888.89 916\" preserveAspectRatio=\"xMinYMin\"><path d=\"M384 0 H504 V916 H384z M384 0 H504 V916 H384z\"/></svg></span></span><span style=\"top:-5.2em;\"><span class=\"pstrut\" style=\"height:3.15em;\"></span><span class=\"delimsizinginner delim-size4\"><span>⎫</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:2.45em;\"><span></span></span></span></span></span></span></span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
      },
      {
       "data": "Out[51]//TableForm= \\left\\{\\begin{pmatrix}1 & 0 & 1\\\\1 & 1 & u+\\frac{\\theta \\,\\kappa2}{\\kappa1-\\kappa2}-\\frac{h\\,\\kappa1}{\\kappa1-\\kappa2}-\\frac{\\theta \\,\\kappa1}{\\kappa1-\\kappa2}\\end{pmatrix},\\begin{pmatrix}2 & 0 & 1\\\\2 & 1 & u+\\frac{\\theta \\,\\kappa2}{\\kappa1-\\kappa2}-\\frac{2\\,h\\,\\kappa1}{\\kappa1-\\kappa2}-\\frac{\\theta \\,\\kappa1}{\\kappa1-\\kappa2}\\\\2 & 2 & u^2+\\frac{h\\,\\kappa2\\,u}{\\kappa1-\\kappa2}+\\frac{2\\,\\theta \\,\\kappa2\\,u}{\\kappa1-\\kappa2}-\\frac{3\\,h\\,\\kappa1\\,u}{\\kappa1-\\kappa2}-\\frac{2\\,\\theta \\,\\kappa1\\,u}{\\kappa1-\\kappa2}+\\frac{\\theta ^2\\,\\kappa2^2}{\\left(\\kappa1-\\kappa2\\right)^2}+\\frac{h\\,\\theta \\,\\kappa2^2}{\\left(\\kappa1-\\kappa2\\right)^2}-\\frac{2\\,\\theta ^2\\,\\kappa1\\,\\kappa2}{\\left(\\kappa1-\\kappa2\\right)^2}-\\frac{4\\,h\\,\\theta \\,\\kappa1\\,\\kappa2}{\\left(\\kappa1-\\kappa2\\right)^2}+\\frac{2\\,h^2\\,\\kappa1^2}{\\left(\\kappa1-\\kappa2\\right)^2}+\\frac{\\theta ^2\\,\\kappa1^2}{\\left(\\kappa1-\\kappa2\\right)^2}+\\frac{3\\,h\\,\\theta \\,\\kappa1^2}{\\left(\\kappa1-\\kappa2\\right)^2}\\end{pmatrix},\\begin{pmatrix}3 & 0 & 1\\\\3 & 1 & u+\\frac{\\theta \\,\\kappa2}{\\kappa1-\\kappa2}-\\frac{3\\,h\\,\\kappa1}{\\kappa1-\\kappa2}-\\frac{\\theta \\,\\kappa1}{\\kappa1-\\kappa2}\\\\3 & 2 & u^2+\\frac{h\\,\\kappa2\\,u}{\\kappa1-\\kappa2}+\\frac{2\\,\\theta \\,\\kap… [latex truncated: 3465 chars total]",
       "mime": "text/plain"
