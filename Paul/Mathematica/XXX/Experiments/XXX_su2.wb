  {
   "kind": 2,
   "value": "(* final definition: normalized SoV measure functional *)\nClearAll[SoVMeasure];\nSoVMeasure[λ_][f_] := Sum[(-1)^i Binomial[λ,i] f[θ+h i], {i,0,λ}];\n(* cross-check against the normalized raw contour-integral form, symbolic f, λ=1,...,6 *)\nTable[Simplify[SoVMeasure[λ][f] - normalizedSum[λ][f]], {λ,1,6}]",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"638911\" data-output-id=\"26\" data-out-n=\"101\" data-sub-idx=\"4\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"39\" data-sub-start=\"4\" data-sub-end=\"4\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[101]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrkoxlqq-hutyfkl\" data-page-width-em=\"12\" data-latex-b64=\"XGxlZnRcezAsMCwwLDAsMCwwXHJpZ2h0XH0=\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">{</span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">0</span><span class=\"mclose delimcenter\" style=\"top:0em;\">}</span></span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
