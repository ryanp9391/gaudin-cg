  {
   "kind": 2,
   "value": "(*monodromy with no twist, diagonal twist, and companion twist*)\nClearAll[T,Tg,TG];\nT[S1_,S2_][i_,j_][u_]:=Sum[KroneckerProduct[L[S1][i,ii][u-θ1],L[S2][ii,j][u-θ2]],{ii,3}];\nTg[S1_,S2_][i_,j_][u_]:= z[i] T[S1,S2][i,j][u];\nTG[S1_,S2_][i_,j_][u_]:=Sum[T[S1,S2][i,ii][u] G[[ii,j]],{ii,3}]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*Yangian weights - i.e. eigenvalues of T[i,i] on highest-weight state*)\nClearAll[ν,HWS]\nν[S1_,S2_][1][u_]=(u-θ1-h S1)(u-θ2-h S2);\nν[S1_,S2_][2][u_]=(u-θ1)(u-θ2);\nν[S1_,S2_][3][u_]=(u-θ1)(u-θ2);\n\nHWS[S1_,S2_]:=Table[{KroneckerDelta[1,ii]},{ii,1,dim[{S1,0,0}]dim[{S2,0,0}]}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*checking highest-weights*)\nTable[T[S1,S2][i,i][u].HWS[S1,S2]-ν[S1,S2][i][u] HWS[S1,S2],{i,3},{S1,1,3},{S2,1,3}]//Flatten//Union",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"352972\" data-output-id=\"313\" data-out-n=\"37\" data-sub-idx=\"1\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"9\" data-sub-start=\"1\" data-sub-end=\"1\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[37]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mroynmag-urahsio\" data-page-width-em=\"21\" data-latex-b64=\"XGxlZnRcezBccmlnaHRcfQ==\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"minner\"><span class=\"mopen delimcenter\" style=\"top:0em;\">{</span><span class=\"mord\">0</span><span class=\"mclose delimcenter\" style=\"top:0em;\">}</span></span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
      },
      {
       "data": "Out[37]= \\left\\{0\\right\\}",
       "mime": "text/plain"
      }
     ],
     "id": "b9eec810-0d00-48ad-9fd3-b1ff66ef90a1"
    }
   ],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*quantum minors (q-determinants) of the monodromy matrix*)\nClearAll[qmin,qming,qminG];\nqmin[S1_, S2_][II_List, JJ_List][u_] := \n    qmin[S1, S2][II, JJ][u] = \n     Sum[Signature[σ] \n        Dot @@ Table[T[S1, S2][II[[σ[[k]]]], JJ[[k]]][u - (k - 1) h], {k, \n            Length[II]}], {σ, Permutations[Range[Length[II]]]}];\n\nqming[S1_, S2_][II_List, JJ_List][u_] := \n    qming[S1, S2][II, JJ][u] = \n     Sum[Signature[σ] \n        Dot @@ Table[Tg[S1, S2][II[[σ[[k]]]], JJ[[k]]][u - (k - 1) h], {k, \n            Length[II]}], {σ, Permutations[Range[Length[II]]]}];\n\nqminG[S1_, S2_][II_List, JJ_List][u_] := \n    qminG[S1, S2][II, JJ][u] = \n     Sum[Signature[σ] \n        Dot @@ Table[TG[S1, S2][II[[σ[[k]]]], JJ[[k]]][u - (k - 1) h], {k, \n            Length[II]}], {σ, Permutations[Range[Length[II]]]}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*transfer matrices with diagonal twist*)\nClearAll[tg];\ntg[S1_,S2_][a_,1][u_]:= Total[qming[S1, S2][#, #][u] & /@ Subsets[{1, 2, 3}, {a}]]\n\n(*transfer matrices with companion twist*)\nClearAll[tG];\ntG[S1_,S2_][a_,1][u_]:= Total[qminG[S1, S2][#, #][u] & /@ Subsets[{1, 2, 3}, {a}]]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*value of quantum determinant*)\nClearAll[qdetT];\nqdetT[S1_,S2_][u_]:=χ3 ν[S1,S2][1][u-2h]ν[S1,S2][2][u-h]ν[S1,S2][3][u];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*checking quantum determinat has the correct central value*)\nTable[qdetT[S1,S2][u]KroneckerProduct[id[S1],id[S2]]-tg[S1,S2][3,1][u],{S1,3},{S2,3}]//Simplify//Flatten//Union",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
