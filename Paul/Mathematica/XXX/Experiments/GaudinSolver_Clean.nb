       "to", " ", "vanish", " ", "for", " ", "every", " ", "j"}], "<", 
      RowBox[{"k", "."}]}]}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "GaudinSolve", "]"}], ";"}], "\n", 
