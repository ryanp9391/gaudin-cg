   "value": "vac={{1,0,0,0,0,0}}.MatrixExp[α[1,3]Ee[1,3]].MatrixExp[α[1,4]Ee[1,4]].MatrixExp[α[2,3]Ee[2,3]].MatrixExp[α[2,4]Ee[2,4]]/.α[2, 4] -> ((z[2] - z[3])*(z[1] - z[4])*α[1, 4]*α[2, 3])/((z[1] - z[3])*(z[2] - z[4])*α[1, 3])",
