  {
   "kind": 2,
   "value": "ClearAll[L];\nL[i_,j_][u_]:=id u KroneckerDelta[i,j] - h Ee[j,i];\n\nClearAll[T,Tg];\nT[i_,j_][u_]:=L[i,j][u-θ1]\nTg[i_,j_][u_]:= z[i] T[i,j][u];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*quantum minors (q-determinants) of the monodromy matrix*)\nClearAll[qmin,qming,qminG];\nqmin[II_List, JJ_List][u_] := \n    qmin[II, JJ][u] = \n     Sum[Signature[σ] \n        Dot @@ Table[T[II[[σ[[k]]]], JJ[[k]]][u - (k - 1) h], {k, \n            Length[II]}], {σ, Permutations[Range[Length[II]]]}];\n\nqming[II_List, JJ_List][u_] := \n    qming[II, JJ][u] = \n     Sum[Signature[σ] \n        Dot @@ Table[Tg[II[[σ[[k]]]], JJ[[k]]][u - (k - 1) h], {k, \n            Length[II]}], {σ, Permutations[Range[Length[II]]]}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "(*transfer matrices with diagonal twist*)\nClearAll[tg];\ntg[a_,1][u_]:= Total[qming[#, #][u] & /@ Subsets[{1, 2, 3, 4}, {a}]]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "ClearAll[occ, wt, evec, La, polyFac];\n(* GT basis, weights, and transfer-matrix eigenvalues La[a,oc][u], L=1 rep [1,1,0,0] *)\nbasis    = ps[{{1,1,0,0}}];\nwt[s_]   := Table[Diagonal[Ee[i,i]][[s]], {i,4}];     (* weight (E11,E22,E33,E44) *)\nocc[s_]  := Flatten@Position[wt[s], 1];               (* occupied pair {i,j}      *)\nevec[s_] := UnitVector[6, s];                         (* eigenvector             *)\npolyFac[Ii_, O_][u_] := Module[{e = Length@Complement[Ii,O]},\n   Product[u-θ1-s h, {s,0,e-1}] Product[u-θ1-s h, {s,e+1,Length[Ii]}]];\nLa[a_, O_][u_] := Sum[(Times@@(z/@Ii)) polyFac[Ii,O][u], {Ii, Subsets[{1,2,3,4},{a}]}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "ν1[u_]=(u-θ1-h);",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "Bax[Q_]:=Q[u+h]-t[1][u]/ν1[u] Q[u]+t[2][u]/ν1[u]/ν1[u-h]Q[u-h]-t[3][u]/ν1[u]/ν1[u-h]/ν1[u-2h]Q[u-2h]+t[4][u]/ν1[u]/ν1[u-h]/ν1[u-2h]/ν1[u-3h]Q[u-3h];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "ClearAll[qpart, Qfun];\n(* single-index Baxter Q on state oc={i,j}: Qfun[oc,k][u] = z[k]^(u/h)*qpart, monic *)\nqpart[oc_, k_][uu_] := If[MemberQ[oc, k], 1,\n   (uu - θ1) + h (z[oc[[1]]] z[oc[[2]]] - z[k]^2)/((z[k]-z[oc[[1]]]) (z[k]-z[oc[[2]]]))];\nQfun[oc_, k_][uu_] := z[k]^(uu/h) qpart[oc, k][uu];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "Q12[oc_][uu_] := Qfun[oc,1][uu] Qfun[oc,2][uu-h] - Qfun[oc,1][uu-h] Qfun[oc,2][uu];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "Q12[{1,2}][u]",
