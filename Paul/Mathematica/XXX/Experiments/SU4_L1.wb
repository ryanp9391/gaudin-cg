  {
   "kind": 2,
   "value": "ClearAll[Psi];\n(* eigenstate for occupied pair oc={i,j}, normalized so <vac|Psi>=1 *)\nPsi[oc_] := With[{s = First@FirstPosition[Table[occ[k], {k, 6}], oc]},\n   evec[s]/((vac . evec[s])[[1]])];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "br[f_]:=-h(Residue[f/(u-θ1+c h)/(u-θ1-h+c h),{u,θ1-c h}]+Residue[f/(u-θ1+c h )/(u-θ1-h+ c h ),{u,θ1+h-c h}])//Expand",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
