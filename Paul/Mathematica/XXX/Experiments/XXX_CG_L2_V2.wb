       "data": "Out[278]= \\left\\{\\text{Mirror Test1 (u\\^{}j)},\\left\\{0\\right\\},\\text{Mirror Test2 (k\\^{}(u/h)u\\^{}j)},\\left\\{0\\right\\}\\right\\}",
