      {
       "data": "Out[305]= \\begin{pmatrix}\\left\\{0,0\\right\\} & -1.\\,+0.\\,\\,\\mathrm{i}\\\\\\left\\{1,0\\right\\} & 0.05448860910968355 -0.09540961504089102\\,\\mathrm{i}\\\\\\left\\{1,1\\right\\} & -0.0293413933141388+0.7363100318787654\\,\\mathrm{i}\\\\\\left\\{2,0\\right\\} & 0.11703059508534998 +0.\\,\\,\\mathrm{i}\\\\\\left\\{2,1\\right\\} & 0.8158972359113332 +0.\\,\\,\\mathrm{i}\\\\\\left\\{3,0\\right\\} & 0.05448860910968355 +0.09540961504089102\\,\\mathrm{i}\\\\\\left\\{3,1\\right\\} & -0.0293413933141388-0.7363100318787654\\,\\mathrm{i}\\\\\\left\\{4,0\\right\\} & -1.\\,+0.\\,\\,\\mathrm{i}\\end{pmatrix}",
