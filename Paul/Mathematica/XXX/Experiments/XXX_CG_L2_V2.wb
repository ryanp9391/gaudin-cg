      {
       "data": "Out[328]= \\left\\{\\text{Fcand2 (no P-insertion)},k1^2\\,\\left(\\left(0.02466179161444501+1.36288164597304175\\,\\mathrm{i}\\right)-\\left(0.36043987514722654+0.93278244859337472\\,\\mathrm{i}\\right)\\,k2\\right)+k1\\,\\left(\\left(1.2351720155778515-0.69045766735200127\\,\\mathrm{i}\\right)\\,k2-\\left(6.46913785540003854-1.0378703818584163\\,\\mathrm{i}\\right)\\right)+\\left(5.38781822995835893-1.9706528304517910\\,\\mathrm{i}\\right)\\,k2+\\left(1.000000000000000000+0.\\times 10^{-18}\\,\\mathrm{i}\\right),\\text{diff vs O2rot},\\left(0.06092913222392296 +3.3671193606392795\\,\\mathrm{i}\\right)\\,k1^2-\\left(0.06092913222392296 +3.3671193606392795\\,\\mathrm{i}\\right)\\,k1\\,k2-\\left(7.991287939023577 -1.2820751775898085\\,\\mathrm{i}\\right)\\,k1+\\left(7.991287939023577 -1.2820751775898085\\,\\mathrm{i}\\right)\\,k2\\right\\}",
