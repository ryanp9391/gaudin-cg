       "data": "<div class=\"wl-output-block\"><div class=\"wl-output-header\" style=\"display:flex;align-items:center;gap:6px;width:100%;min-height:22px;\" data-session-epoch=\"941596\" data-output-id=\"1070\" data-out-n=\"364\" data-sub-idx=\"6\" data-output-format=\"WLLatex\" data-output-is-graphics=\"0\" data-cell-idx=\"109\" data-sub-start=\"8\" data-sub-end=\"9\"><span style=\"font-size:10px;color:#888;margin-right:8px;\">Out[364]=</span></div><div class=\"wl-output-content\"><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrqpzgq0-totya3g\" data-page-width-em=\"21\" data-latex-b64=\"\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:10.8001em;vertical-align:-5.1501em;\"></span><span class=\"minner\"><span class=\"mopen\"><span class=\"delimsizing mult\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:5.65em;\"><span style=\"top:-1.366em;\"><span class=\"pstrut\" style=\"height:5.616em;\"></span><span class=\"delimsizinginner delim-size4\"><span>⎩</span></span></span><span style=\"top:-1.358em;\"><span class=\"pstrut\" style=\"height:5.616em;\"></span><span style=\"height:3.616em;width:0.8889em;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"0.8889em\" height=\"3.616em\" style=\"width:0.8889em\" viewBox=\"0 0 888.89 3616\" preserveAspectRatio=\"xMinYMin\"><path d=\"M384 0 H504 V3616 H384z M384 0 H504 V3616 H384z\"/></svg></span></span><span style=\"top:-5.616em;\"><span class=\"pstrut\" style=\"height:5.616em;\"></span><span class=\"delimsizinginner delim-size4\"><span>⎨</span></span></span><span style=\"top:-6.758em;\"><span class=\"pstrut\" style=\"height:5.616em;\"></span><span style=\"height:3.616em;width:0.8889em;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"0.8889em\" height=\"3.616