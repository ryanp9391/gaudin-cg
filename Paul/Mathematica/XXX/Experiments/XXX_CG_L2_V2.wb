012</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">−</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mord\">1.3456153260557858257</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathrm\">i</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">7.3660840301643179118107</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">+</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mord\">0.9680462997944614002659</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathrm\">i</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">2.68702160063169134011892</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">+</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mord\">1.3456153260557858257399</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathrm\">i</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\">2.909064289315083263084</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">+</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mord\">5.804620063565933843043</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathrm\">i</span><span class=\"mclose delimcenter\" style=\"top:0em;\">}</span></span><span class=\"mclose\">∣</span><span class=\"mspace\" style=\"margin-right:-0.1667em;\"></span><span class=\"mclose\">⟩</span></span></span></span></span></div></div></div></div>",
       "mime": "x-application/wolfram-language-html"
      },
      {
       "data": "Out[136]= \\langle\\!\\lvert \\text{states}\\to \\begin{pmatrix}0 & 0\\\\1 & 0\\\\1 & 1\\\\2 & 0\\\\2 & 1\\\\3 & 0\\end{pmatrix},\\text{max|off-diagonal|}\\to 5.065342385207116\\times 10^{-34},\\text{digits vanished (-Log10)}\\to 33.29539119374288,\\text{min|diagonal|}\\to 3.0051232400647923,\\text{diagonal values}\\to \\left\\{2.9090642893150832630837933001-5.8046200635659338430425538562\\,\\mathrm{i},7.36608403016431791181-0.968046299794461400266\\,\\mathrm{i},2.68702160063169134012-1.3456153260557858257\\,\\mathrm{i},7.3660840301643179118107+0.9680462997944614002659\\,\\mathrm{i},2.68702160063169134011892+1.3456153260557858257399\\,\\mathrm{i},2.909064289315083263084+5.804620063565933843043\\,\\mathrm{i}\\right\\}\\rvert\\!\\rangle",
