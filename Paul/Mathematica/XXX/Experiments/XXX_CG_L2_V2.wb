      {
       "data": "Out[377]= \\langle\\!\\lvert \\text{states}\\to \\begin{pmatrix}0 & 0\\\\1 & 0\\\\1 & 1\\\\2 & 0\\\\2 & 1\\\\3 & 0\\end{pmatrix},\\text{$\\varphi$ candidates per state}\\to \\begin{pmatrix}\\left\\{0,0\\right\\} & \\left(-0.920793778924720536105378676-0.390049761817044163511250929\\,\\mathrm{i}\\right)\\,k^{4/3}+\\left(0.695722366612934233848844287-0.718310788304406529935213657\\,\\mathrm{i}\\right)\\,\\sqrt[3]{k}-\\left(0.36043987514722653726667765-0.932782448593374716484835982\\,\\mathrm{i}\\right)\\\\\\left\\{1,0\\right\\} & \\left(0.405551697951133231+0.6700728126509917405\\,\\mathrm{i}\\right)\\,k^{4/3}+\\left(0.230294883363374457+1.020465255165547760\\,\\mathrm{i}\\right)\\,\\sqrt[3]{k}+\\left(1.266863606063179532+0.423064177199644807\\,\\mathrm{i}\\right)\\\\\\left\\{1,1\\right\\} & \\left(1.026330510271804681-0.6930042968780183278\\,\\mathrm{i}\\right)\\,k^{4/3}-\\left(0.8580475488602056847-1.118017523538099790\\,\\mathrm{i}\\right)\\,\\sqrt[3]{k}-\\left(1.079434870986621732-0.3604730796187899548\\,\\mathrm{i}\\right)\\\\\\left\\{2,0\\right\\} & \\left(-0.101618670817164685209-0.333121777040865815432\\,\\mathrm{i}\\right)\\,k^{4/3}-\\left(0.269668886265857864341+0.379028636362780419275\\,\\mathrm{i}\\right)\\,\\sqrt[3]{k}+\\left(1.26686360606317953187-0.423064177199644807095\\,\\math… [latex truncated: 3007 chars total]",
