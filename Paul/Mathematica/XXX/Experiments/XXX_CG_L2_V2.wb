      {
       "data": "Out[525]= \\left\\{\\text{A-block ($\\lambda$1=2,$\\lambda$2=1, L=2, s,s'=1,2)},\\begin{pmatrix}\\frac{25}{46} & \\frac{21}{46}\\\\0 & 1\\end{pmatrix},\\text{its inverse (should = B row)},\\begin{pmatrix}\\frac{46}{25} & -\\frac{21}{25}\\\\0 & 1\\end{pmatrix},\\text{Step2's independently-solved B row \\{1,1\\}},\\left\\{\\frac{46}{25},-\\frac{21}{25}\\right\\},\\text{match?},\\left\\{0,0\\right\\}\\right\\}",
