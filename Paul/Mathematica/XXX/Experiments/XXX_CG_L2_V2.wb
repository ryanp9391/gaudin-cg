       "data": "Out[557]= \\begin{pmatrix}0 & 0 & 1.\\, & 1.\\, & 0\\\\0 & 1 & -2.603469709065218-0.6885776528619827\\,\\mathrm{i} & 5.387818229958359 -1.970652830451791\\,\\mathrm{i} & -7.991287939023577+1.2820751775898085\\,\\mathrm{i}\\\\1 & 0 & 1.5221500836235384 -0.24420479573139206\\,\\mathrm{i} & -6.469137855400039+1.0378703818584163\\,\\mathrm{i} & 7.991287939023577 -1.2820751775898085\\,\\mathrm{i}\\\\1 & 1 & 1.2961011478017745 +2.6766616932872784\\,\\mathrm{i} & 1.2351720155778516 -0.6904576673520013\\,\\mathrm{i} & 0.06092913222392296 +3.3671193606392795\\,\\mathrm{i}\\\\2 & 0 & -0.03626734060947795-2.004237714666238\\,\\mathrm{i} & 0.024661791614445008 +1.3628816459730417\\,\\mathrm{i} & -0.06092913222392296-3.3671193606392795\\,\\mathrm{i}\\\\2 & 1 & -0.36043987514722653-0.9327824485933747\\,\\mathrm{i} & -0.36043987514722653-0.9327824485933747\\,\\mathrm{i} & 0\\end{pmatrix}",
