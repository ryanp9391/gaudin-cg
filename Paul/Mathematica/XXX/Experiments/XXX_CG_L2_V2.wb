       "data": "Out[515]= \\begin{pmatrix}\\left\\{0,0,\\left\\{\\text{srng},\\left\\{0\\right\\},\\text{sol},\\left\\{1.\\,\\right\\},\\text{maxResid},0.\\times 10^{-28}\\right\\}\\right\\} & \\left\\{0,1,\\left\\{\\text{srng},\\left\\{0,1\\right\\},\\text{sol},\\left\\{11.50000000000000000000000000-4.431302171530629069010197265\\times 10^{-38}\\,\\mathrm{i},-10.50000000000000000000000000+2.933894180666706878219239219\\times 10^{-38}\\,\\mathrm{i}\\right\\},\\text{maxResid},0.\\times 10^{-27}\\right\\}\\right\\}\\\\\\left\\{1,0,\\left\\{\\text{srng},\\left\\{0,1\\right\\},\\text{sol},\\left\\{0,1.\\,\\right\\},\\text{maxResid},0.\\times 10^{-28}\\right\\}\\right\\} & \\left\\{1,1,\\left\\{\\text{srng},\\left\\{1,2\\right\\},\\text{sol},\\left\\{1.84-1.138307775194886361676504399\\times 10^{-39}\\,\\mathrm{i},-0.84+7.937073885996337812603867042\\times 10^{-40}\\,\\mathrm{i}\\right\\},\\text{maxResid},0.\\times 10^{-27}\\right\\}\\right\\}\\\\\\left\\{2,0,\\left\\{\\text{srng},\\left\\{1,2\\right\\},\\text{sol},\\left\\{0,1.\\,\\right\\},\\text{maxResid},0.\\times 10^{-27}\\right\\}\\right\\} & \\left\\{2,1,\\left\\{\\text{srng},\\left\\{2\\right\\},\\text{sol},\\left\\{1.\\,\\right\\},\\text{maxResid},0.\\times 10^{-28}\\right\\}\\right\\}\\end{pmatrix}",
