      {
       "data": "Out[373]= \\begin{pmatrix}1 & 0 & \\frac{4}{25}\\\\1 & 1 & 1\\\\2 & 0 & \\frac{2}{23}\\\\2 & 1 & \\frac{25}{46}\\\\2 & 2 & 1\\\\3 & 0 & \\frac{4}{67}\\\\3 & 1 & \\frac{25}{67}\\\\3 & 2 & \\frac{46}{67}\\\\3 & 3 & 1\\end{pmatrix}",
