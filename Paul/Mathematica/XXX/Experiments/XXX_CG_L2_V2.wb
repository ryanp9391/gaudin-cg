       "data": "Out[484]= \\begin{pmatrix}0 & 0 & 0.8405990749714453 -0.5416578210984777\\,\\mathrm{i} & 4.04123637990545\\\\0 & 1 & 0.8405990749714453 -0.5416578210984777\\,\\mathrm{i} & 4.04123637990545\\\\1 & 0 & 0.8405990749714453 -0.5416578210984777\\,\\mathrm{i} & 4.04123637990545\\\\1 & 1 & 0.8405990749714453 -0.5416578210984777\\,\\mathrm{i} & 4.04123637990545\\\\2 & 0 & 0.8405990749714453 -0.5416578210984777\\,\\mathrm{i} & 4.04123637990545\\\\2 & 1 & 0.8405990749714453 -0.5416578210984777\\,\\mathrm{i} & 4.04123637990545\\end{pmatrix}",
