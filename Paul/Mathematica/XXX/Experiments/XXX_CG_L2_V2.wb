      {
       "data": "Out[382]= \\begin{pmatrix}1 & 0 & 1 & \\frac{4}{25}\\\\1 & 0 & 2 & -\\frac{17}{25}\\\\1 & 0 & 3 & -\\frac{38}{25}\\\\1 & 1 & 1 & 1\\\\1 & 1 & 2 & 1\\\\1 & 1 & 3 & 1\\\\2 & 0 & 1 & \\frac{2}{23}\\\\2 & 0 & 2 & -\\frac{34}{575}\\\\2 & 0 & 3 & \\frac{323}{575}\\\\2 & 1 & 1 & \\frac{25}{46}\\\\2 & 1 & 2 & \\frac{2}{23}\\\\2 & 1 & 3 & -\\frac{17}{46}\\\\2 & 2 & 1 & 1\\\\2 & 2 & 2 & 1\\\\2 & 2 & 3 & 1\\\\3 & 0 & 1 & \\frac{4}{67}\\\\3 & 0 & 2 & -\\frac{34}{1541}\\\\3 & 0 & 3 & \\frac{1292}{38525}\\\\3 & 1 & 1 & \\frac{25}{67}\\\\3 & 1 & 2 & \\frac{50}{1541}\\\\3 & 1 & 3 & -\\frac{34}{1541}\\\\3 & 2 & 1 & \\frac{46}{67}\\\\3 & 2 & 2 & \\frac{25}{67}\\\\3 & 2 & 3 & \\frac{4}{67}\\\\3 & 3 & 1 & 1\\\\3 & 3 & 2 & 1\\\\3 & 3 & 3 & 1\\end{pmatrix}",
