      {
       "data": "Out[472]//MatrixForm= \\begin{pmatrix}\\frac{\\left(\\theta A-\\theta B+2\\right)\\,\\left(\\theta A-\\theta B+3\\right)}{\\theta A^2-2\\,\\theta A\\,\\theta B-\\theta A+\\theta B^2+\\theta B} & -\\frac{6\\,\\left(\\theta A-\\theta B+3\\right)}{\\theta A^2-2\\,\\theta A\\,\\theta B+\\theta B^2-1} & \\frac{6}{\\left(\\theta A-\\theta B\\right)\\,\\left(\\theta A-\\theta B+1\\right)}\\\\0 & \\frac{\\theta A-\\theta B+3}{\\theta A-\\theta B+1} & -\\frac{2}{\\theta A-\\theta B+1}\\\\0 & 0 & 1\\end{pmatrix}",
       "mime": "text/plain"
      }
