      {
       "data": "Out[538]= \\left\\{\\text{TRUE sum rule (derived, Step 4): worst deviation},0,\\text{num ($\\lambda$1,$\\lambda$2,s,t) cases},20,\\text{sample},\\begin{pmatrix}2 & 1 & 0 & 0 & 0\\\\2 & 1 & 0 & 1 & 0\\\\2 & 1 & 1 & 0 & 0\\\\2 & 1 & 1 & 1 & 0\\\\2 & 1 & 2 & 0 & 0\\\\2 & 1 & 2 & 1 & 0\\end{pmatrix}\\right\\}",
       "mime": "text/plain"
      }
