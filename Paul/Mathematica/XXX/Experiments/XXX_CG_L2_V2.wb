      {
       "data": "Out[404]= \\langle\\!\\lvert \\text{validation}\\to \\left\\{\\left\\{1,1\\right\\}\\to \\begin{pmatrix}\\left\\{0,0\\right\\} & 0\\\\\\left\\{1,0\\right\\} & 0\\\\\\left\\{1,1\\right\\} & 0\\\\\\left\\{2,0\\right\\} & 0\\end{pmatrix},\\left\\{2,1\\right\\}\\to \\begin{pmatrix}\\left\\{0,0\\right\\} & 0\\\\\\left\\{1,0\\right\\} & 0\\\\\\left\\{1,1\\right\\} & 0\\\\\\left\\{2,0\\right\\} & 0\\\\\\left\\{2,1\\right\\} & 0\\\\\\left\\{3,0\\right\\} & 0\\end{pmatrix},\\left\\{1,2\\right\\}\\to \\begin{pmatrix}\\left\\{0,0\\right\\} & 0\\\\\\left\\{1,0\\right\\} & 0\\\\\\left\\{1,1\\right\\} & 0\\\\\\left\\{2,0\\right\\} & 0\\\\\\left\\{2,1\\right\\} & 0\\\\\\left\\{3,0\\right\\} & 0\\end{pmatrix},\\left\\{2,2\\right\\}\\to \\begin{pmatrix}\\left\\{0,0\\right\\} & 0\\\\\\left\\{1,0\\right\\} & 0\\\\\\left\\{1,1\\right\\} & 0\\\\\\left\\{2,0\\right\\} & 0\\\\\\left\\{2,1\\right\\} & 0\\\\\\left\\{2,2\\right\\} & 0\\\\\\left\\{3,0\\right\\} & 0\\\\\\left\\{3,1\\right\\} & 0\\\\\\left\\{4,0\\right\\} & 0\\end{pmatrix},\\left\\{3,1\\right\\}\\to \\begin{pmatrix}\\left\\{0,0\\right\\} & 0\\\\\\left\\{1,0\\right\\} & 0\\\\\\left\\{1,1\\right\\} & 0\\\\\\left\\{2,0\\right\\} & 0\\\\\\left\\{2,1\\right\\} & 0\\\\\\left\\{3,0\\right\\} & 0\\\\\\left\\{3,1\\right\\} & 0\\\\\\left\\{4,0\\right\\} & 0\\end{pmatrix},\\left\\{1,3\\right\\}\\to \\begin{pmatrix}\\left\\{0,0\\right\\} & 0\\\\\\left\\{1,0\\right\\} & 0\\\\\\left\\{1,1\\right\\} & 0\\\\\\left\\{2,0… [latex truncated: 1417 chars total]",
