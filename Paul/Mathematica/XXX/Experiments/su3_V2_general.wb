       "data": "Out[27]= \\left\\{\\frac{1}{3},\\frac{1}{7},1,0.360439875147226537266677650596+0.932782448593374716484835982071\\,\\mathrm{i},0.508867380990499828163321372267+0.860844927129079093188644393616\\,\\mathrm{i},0.533257880589599372595832345093+0.845952736734794526483381618453\\,\\mathrm{i},1.40256513672732573802583136796+2.63958011245724833615686199414\\,\\mathrm{i},-1.6733239859016290991182472189+2.47680418504351011497841273933\\,\\mathrm{i},-0.99441459784152865778064561506-0.1055443394961133295075060113\\,\\mathrm{i}\\right\\}",
