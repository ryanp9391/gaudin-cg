  {
   "kind": 2,
   "value": "\ndoRes0[S1_,S2_,f_]:=Module[{nmax,coeffs,res},\n  nmax=Exponent[f,u];\n  coeffs=CoefficientList[f,u];\n  res=Plus@@(coeffs Table[res0[n,S1,S2],{n,0,nmax}]);\n  res\n  ]\n\ndoRes1[S1_,S2_,f_]:=Module[{nmax,coeffs,res},\n  nmax=Exponent[f,u];\n  coeffs=CoefficientList[f,u];\n  res=Plus@@(coeffs Table[res1[n,S1,S2],{n,0,nmax}]);\n  res\n  ]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {}
  },
