      {
       "data": "Out[30]= \\frac{7\\,u^{20}}{2}-\\frac{13\\,u^{18}}{10}-\\frac{u^{17}}{5}-\\frac{u^{16}}{10}+\\frac{3\\,u^{15}}{2}-2\\,u^{14}-\\frac{7\\,u^{13}}{3}+\\frac{2\\,u^{12}}{5}-5\\,u^{11}-\\frac{11\\,u^{10}}{2}+6\\,u^9+\\frac{2\\,u^8}{5}+\\frac{15\\,u^7}{7}-\\frac{20\\,u^6}{9}+\\frac{13\\,u^5}{9}-\\frac{4\\,u^4}{7}-\\frac{20\\,u^3}{7}-\\frac{17\\,u^2}{4}-4\\,u+\\frac{7}{5}",
